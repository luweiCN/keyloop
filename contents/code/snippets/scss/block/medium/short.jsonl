{"text":"@function zf-is-fraction($value, $allow-no-denominator: false) {\n  $parsed: zf-parse-fraction($value);\n  @return not(nth($parsed, 1) == null\n    or (nth($parsed, 2) == null and $allow-no-denominator == false));\n}","source":"v3-scss-foundation-0005","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@function smart-scale($color, $scale: 5%, $threshold: 40%) {\n  @if color.channel($color, \"lightness\", $space: hsl) > $threshold {\n    $scale: -$scale;\n  }\n  @return scale-color($color, $lightness: $scale);\n}","source":"v3-scss-foundation-0016","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":7}
{"text":"@function map-deep-get($map, $keys...) {\n  @each $key in $keys {\n    $map: map-get($map, $key);\n  }\n  @return $map;\n}","source":"v3-scss-foundation-0022","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@function bulmaFindColorInvert($color) {\n  @if bulmaColorLuminance($color) > 0.55 {\n    @return rgba(#000, 0.7);\n  } @else {\n    @return #fff;\n  }\n}","source":"v3-scss-bulma-0015","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@function bulmaDarken($color, $amount) {\n  @if meta.type-of($color) != \"color\" {\n    @return $color;\n  }\n\n  @return color.adjust($color, $lightness: -$amount, $space: hsl);\n}","source":"v3-scss-bulma-0017","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":7}
{"text":"@mixin auto-width($max, $elem: li) {\n  @for $i from 2 through $max {\n    &:nth-last-child(#{$i}):first-child,\n    &:nth-last-child(#{$i}):first-child ~ #{$elem} {\n      width: percentage(divide(1, $i));\n    }\n  }\n}","source":"v3-scss-foundation-0028","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@function bulmaRgba($color, $alpha) {\n  @if meta.type-of($color) != \"color\" {\n    @return $color;\n  }\n\n  @return rgba($color, $alpha);\n}","source":"v3-scss-bulma-0016","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":6}
{"text":"@mixin code-style {\n  border: $code-border;\n  background-color: $code-background;\n\n  font-family: $code-font-family;\n  font-weight: $code-font-weight;\n  color: $code-color;\n}","source":"v3-scss-foundation-0044","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":7}
{"text":"@function map-merge-multiple($maps...) {\n  $merged-maps: ();\n\n  @each $map in $maps {\n    $merged-maps: map-merge($merged-maps, $map);\n  }\n  @return $merged-maps;\n}","source":"v3-scss-bootstrap-0006","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@mixin block($spacing: cv.getVar(\"block-spacing\")) {\n  &:not(:last-child) {\n    margin-bottom: $spacing;\n  }\n}","source":"v3-scss-bulma-0018","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@each $alignment, $text-align in $alignments {\n  .#{iv.$class-prefix}#{iv.$helpers-has-prefix}text-#{$alignment} {\n    text-align: #{$text-align} !important;\n  }\n}","source":"v3-scss-bulma-0020","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@function buildHslaString($name, $l, $a: 1) {\n  $lightness: getVar($name, \"\", \"-l\");\n  @if ($l) {\n    $lightness: $l;\n  }\n  @return \"hsla(#{getVar($name, '', '-h')}, #{getVar($name, '', '-s')}, #{$lightness}, #{$a})\";\n}","source":"v3-scss-bulma-0021","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":7}
{"text":"@mixin register-base-color($name, $base) {\n  $hsla: buildHslaString($name, getVar($name, \"\", \"-l\"));\n  @include register-var($name, $hsla);\n  @include register-var($name, $hsla, \"\", \"-base\"); // Just for reference\n  @include register-rgb($name, $base);\n  @include register-hsl($name, $base);\n}","source":"v3-scss-bulma-0022","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@function varify($list) {\n  $result: null;\n  @each $entry in $list {\n    $result: append($result, var(--#{$prefix}#{$entry}), space);\n  }\n  @return $result;\n}","source":"v3-scss-bootstrap-0005","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":7}
{"text":"@mixin gradient-bg($color: null) {\n  background-color: $color;\n\n  @if $enable-gradients {\n    background-image: var(--#{$prefix}gradient);\n  }\n}","source":"v3-scss-bootstrap-0029","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@mixin row-cols($count) {\n  > * {\n    flex: 0 0 auto;\n    width: percentage(divide(1, $count));\n  }\n}","source":"v3-scss-bootstrap-0036","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@mixin svg-fill($src, $color-default, $color-new) {\n    $replace-src: str-replace($src, $color-default, $color-new) !default;\n    $replace-src: str-replace($replace-src, '#', '%23');\n    $replace-src: string.quote($replace-src);\n    background-image: url($replace-src);\n}","source":"v3-scss-uikit-0028","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":7}
{"text":"@mixin overlay($offset: 0) {\n  bottom: $offset;\n  left: $offset;\n  position: absolute;\n  right: $offset;\n  top: $offset;\n}","source":"v3-scss-bulma-0019","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":6}
{"text":"@each $color, $value in $ripple {\n  .ripple-surface-#{$color} {\n    .ripple-wave {\n      @include ripple-variant($value);\n    }\n  }\n}","source":"v3-scss-mdb-0020","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"@function _fetch-bourbon-setting($setting) {\n  @return map-get(map-merge($_bourbon-defaults, $bourbon), $setting);\n}","source":"v3-scss-bourbon-0015","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":6}
{"text":"// Clearfix mixin\n@mixin clearfix() {\n  &::after {\n    clear: both;\n    content: \"\";\n    display: table;\n  }\n}","source":"v3-scss-spectre-0005","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":8}
{"text":"// Text Ellipsis\n@mixin text-ellipsis() {\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}","source":"v3-scss-spectre-0006","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":6}
