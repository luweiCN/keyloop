{"text":"// Label base style\n@mixin label-base() {\n  border-radius: $border-radius;\n  line-height: 1.25;\n  padding: .1rem .2rem;\n}","source":"v3-scss-spectre-0001","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":7}
{"text":"// Toast variant mixin\n@mixin toast-variant($color: $dark-color) {\n  background: rgba($color, .95);\n  border-color: $color;\n}","source":"v3-scss-spectre-0007","language":"scss","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":6}
