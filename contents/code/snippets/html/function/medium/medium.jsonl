{"text":"<mat-tree-node\n    [matTreeNodePaddingIndent]=\"childrenIndent()\"\n    *matTreeNodeDef=\"let node\"\n    matTreeNodePadding\n  >\n    <div class=\"prop-row non-expandable-node\">\n      @if (!omitRootNodesNames() || node.level > 0) {\n        <span class=\"name\">{{ node.prop.name }}</span\n        >:\n      }\n      @if (!node.prop.descriptor.editable || !editingEnabled()) {\n        <ng-property-preview class=\"value\" (inspect)=\"propInspect.emit(node)\" [node]=\"node\" />\n      } @else {\n        <ng-property-editor\n          class=\"value\"\n          [property]=\"node.prop\"\n          (updateValue)=\"propValueUpdate.emit({node, newValue: $event})\"\n        />\n      }\n      @if (contentTemplateRef(); as contentTemplateRef) {\n        <ng-container\n          [ngTemplateOutlet]=\"contentTemplateRef\"\n          [ngTemplateOutletContext]=\"{$implicit: node}\"\n        />\n      }\n    </div>\n  </mat-tree-node>","source":"v4-html-angular-angular-devtools-projects-ng-devtools-src-lib-shared-object-tree-explorer-object-tree-explorer-component-html-8-34-0297","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"medium","score":10}
{"text":"<mat-tree-node\n    [matTreeNodePaddingIndent]=\"childrenIndent()\"\n    *matTreeNodeDef=\"let node; when: hasChild\"\n    matTreeNodePadding\n    [isExpandable]=\"node.isExpandable\"\n  >\n    <button matTreeNodeToggle class=\"prop-row expandable-node\">\n      <mat-icon class=\"expand-icon\">\n        {{ tree.isExpanded(node) ? 'expand_more' : 'chevron_right' }}\n      </mat-icon>\n      @if (!omitRootNodesNames() || node.level > 0) {\n        <span class=\"name\">{{ node.prop.name }}</span\n        >:\n      }\n      <span class=\"value\">{{ node.prop.descriptor.preview }}</span>\n      @if (contentTemplateRef(); as contentTemplateRef) {\n        <ng-container\n          [ngTemplateOutlet]=\"contentTemplateRef\"\n          [ngTemplateOutletContext]=\"{$implicit: node}\"\n        />\n      }\n    </button>\n  </mat-tree-node>","source":"v4-html-angular-angular-devtools-projects-ng-devtools-src-lib-shared-object-tree-explorer-object-tree-explorer-component-html-35-57-0299","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"medium","score":9}
{"text":"<section class=\"main\">\n    <input id=\"toggle-all\" class=\"toggle-all\" type=\"checkbox\" />\n    <label for=\"toggle-all\">Mark all as complete</label>\n    <!--  {{slowBinding}}-->\n    <ul class=\"todo-list\">\n      <!-- These are here just to show the structure of the list items -->\n      <!-- List items should get the class `editing` when editing and `completed` when marked as completed -->\n      @for (todo of todos | todosFilter: filterValue; track $index) {\n        <app-todo\n          appTooltip\n          [todo]=\"todo\"\n          (delete)=\"onDelete($event)\"\n          (update)=\"onChange($event)\"\n        />\n      }\n    </ul>\n  </section>","source":"v4-html-angular-angular-devtools-src-app-demo-app-todo-home-todos-component-html-14-30-0313","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"medium","score":7}
{"text":"<section id=\"main\">\n    <input id=\"toggle-all\" type=\"checkbox\" (click)=\"toggleAll($event)\" />\n    <label for=\"toggle-all\">Mark all as complete</label>\n\n    <ul id=\"todo-list\">\n      <li *ngFor=\"let todo of todoStore.list\">\n        <div class=\"view\" [class.hidden]=\"todoEdit == todo\">\n          <input\n            class=\"toggle\"\n            type=\"checkbox\"\n            (click)=\"completeMe(todo)\"\n            [checked]=\"todo.completed\"\n          />\n\n          <label (dblclick)=\"editTodo(todo)\">{{ todo.title }}</label>\n          <button class=\"destroy\" (click)=\"deleteMe(todo)\"></button>\n        </div>\n\n        <div>\n          <input\n            class=\"edit\"\n            [class.visible]=\"todoEdit == todo\"\n            [value]=\"todo.title\"\n            (keyup)=\"doneEditing($event, todo)\"\n          />\n        </div>\n      </li>\n    </ul>\n  </section>","source":"v4-html-angular-angular-modules-playground-src-todo-todo-html-17-45-0338","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"medium","score":9}
{"text":"<ul id=\"todo-list\">\n      <li *ngFor=\"let todo of todoStore.list\">\n        <div class=\"view\" [class.hidden]=\"todoEdit == todo\">\n          <input\n            class=\"toggle\"\n            type=\"checkbox\"\n            (click)=\"completeMe(todo)\"\n            [checked]=\"todo.completed\"\n          />\n\n          <label (dblclick)=\"editTodo(todo)\">{{ todo.title }}</label>\n          <button class=\"destroy\" (click)=\"deleteMe(todo)\"></button>\n        </div>\n\n        <div>\n          <input\n            class=\"edit\"\n            [class.visible]=\"todoEdit == todo\"\n            [value]=\"todo.title\"\n            (keyup)=\"doneEditing($event, todo)\"\n          />\n        </div>\n      </li>\n    </ul>","source":"v4-html-angular-angular-modules-playground-src-todo-todo-html-21-44-0339","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"medium","score":9}
{"text":"<el-row :gutter=\"12\">\n    <el-col :span=\"10\" :xs=\"{ span: 12 }\">\n      <div class=\"demo-color-box\" :style=\"{ background: primary }\">\n        Brand Color\n        <div class=\"value\" text=\"xs\">{{ primary.toUpperCase() }}</div>\n        <div class=\"bg-color-sub\" :style=\"{ background: primary }\">\n          <div\n            v-for=\"level in colorLevel\"\n            :key=\"level\"\n            class=\"bg-blue-sub-item cursor-pointer hover:shadow\"\n            :style=\"{\n              width: `${100 / 6}%`,\n              background: 'var(--el-color-primary-' + level + ')',\n            }\"\n            @click=\"copyColor('primary-' + level)\"\n          />\n        </div>\n      </div>\n    </el-col>\n  </el-row>","source":"v4-html-element-plus-element-plus-docs-vitepress-vitepress-components-globals-main-color-vue-13-32-0021","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"medium","score":10}
{"text":"<el-col :span=\"10\" :xs=\"{ span: 12 }\">\n      <div class=\"demo-color-box\" :style=\"{ background: primary }\">\n        Brand Color\n        <div class=\"value\" text=\"xs\">{{ primary.toUpperCase() }}</div>\n        <div class=\"bg-color-sub\" :style=\"{ background: primary }\">\n          <div\n            v-for=\"level in colorLevel\"\n            :key=\"level\"\n            class=\"bg-blue-sub-item cursor-pointer hover:shadow\"\n            :style=\"{\n              width: `${100 / 6}%`,\n              background: 'var(--el-color-primary-' + level + ')',\n            }\"\n            @click=\"copyColor('primary-' + level)\"\n          />\n        </div>\n      </div>\n    </el-col>","source":"v4-html-element-plus-element-plus-docs-vitepress-vitepress-components-globals-main-color-vue-14-31-0022","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"medium","score":10}
