{"text":"<el-form\n    ref=\"formRef\"\n    :model=\"dynamicValidateForm\"\n    label-width=\"120px\"\n    class=\"demo-dynamic\"\n  >\n    <el-form-item\n      prop=\"email\"\n      label=\"Email\"\n      :rules=\"[\n        {\n          required: true,\n          message: 'Please input email address',\n          trigger: 'blur',\n        },\n        {\n          type: 'email',\n          message: 'Please input correct email address',\n          trigger: ['blur', 'change'],\n        },\n      ]\"\n    >\n      <el-input v-model=\"dynamicValidateForm.email\" />\n    </el-form-item>\n    <el-form-item\n      v-for=\"(domain, index) in dynamicValidateForm.domains\"\n      :key=\"domain.key\"\n      :label=\"'Domain' + index\"\n      :prop=\"'domains.' + index + '.value'\"\n      :rules=\"{\n        required: true,\n        message: 'domain can not be null',\n        trigger: 'blur',\n      }\"\n    >\n      <el-input v-model=\"domain.value\" />\n      <el-button style=\"margin-top: 8px\" @click.prevent=\"removeDomain(domain)\"\n        >Delete</el-button\n      >\n    </el-form-item>\n    <el-form-item>\n      <el-button type=\"primary\" @click=\"submitForm(formRef)\">Submit</el-button>\n      <el-button @click=\"addDomain\">New domain</el-button>\n      <el-button @click=\"resetForm(formRef)\">Reset</el-button>\n    </el-form-item>\n  </el-form>","source":"v4-html-element-plus-element-plus-ssr-testing-cases-form-vue-2-47-0249","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"medium","score":9}
{"text":"<el-row>\n    <el-col :sm=\"12\" :lg=\"6\">\n      <el-result\n        icon=\"success\"\n        title=\"Success Tip\"\n        sub-title=\"Please follow the instructions\"\n      >\n        <template #extra>\n          <el-button type=\"primary\">Back</el-button>\n        </template>\n      </el-result>\n    </el-col>\n    <el-col :sm=\"12\" :lg=\"6\">\n      <el-result\n        icon=\"warning\"\n        title=\"Warning Tip\"\n        sub-title=\"Please follow the instructions\"\n      >\n        <template #extra>\n          <el-button type=\"primary\">Back</el-button>\n        </template>\n      </el-result>\n    </el-col>\n    <el-col :sm=\"12\" :lg=\"6\">\n      <el-result\n        icon=\"error\"\n        title=\"Error Tip\"\n        sub-title=\"Please follow the instructions\"\n      >\n        <template #extra>\n          <el-button type=\"primary\">Back</el-button>\n        </template>\n      </el-result>\n    </el-col>\n    <el-col :sm=\"12\" :lg=\"6\">\n      <el-result icon=\"info\" title=\"Info Tip\">\n        <template #sub-title>\n          <p>Using slot as subtitle</p>\n        </template>\n        <template #extra>\n          <el-button type=\"primary\">Back</el-button>\n        </template>\n      </el-result>\n    </el-col>\n  </el-row>","source":"v4-html-element-plus-element-plus-ssr-testing-cases-result-vue-2-46-0257","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"medium","score":10}
