{"text":"<section id=\"main\">\n    <input id=\"toggle-all\" type=\"checkbox\" (click)=\"toggleAll($event)\" />\n    <label for=\"toggle-all\">Mark all as complete</label>\n\n    <ul id=\"todo-list\">\n      <li *ngFor=\"let todo of todoStore.list\">\n        <div class=\"view\" [class.hidden]=\"todoEdit == todo\">\n          <input\n            class=\"toggle\"\n            type=\"checkbox\"\n            (click)=\"completeMe(todo)\"\n            [checked]=\"todo.completed\"\n          />\n\n          <label (dblclick)=\"editTodo(todo)\">{{ todo.title }}</label>\n          <button class=\"destroy\" (click)=\"deleteMe(todo)\"></button>\n        </div>\n\n        <div>\n          <input\n            class=\"edit\"\n            [class.visible]=\"todoEdit == todo\"\n            [value]=\"todo.title\"\n            (keyup)=\"doneEditing($event, todo)\"\n          />\n        </div>\n      </li>\n    </ul>\n  </section>","source":"v4-html-angular-angular-modules-playground-src-todo-todo-html-17-45-0338","language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"hard","score":9}
