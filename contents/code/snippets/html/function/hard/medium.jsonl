{"text":"<ul class=\"docs-faceted-list\">\n      <!-- TODO: Hide li elements with class docs-toc-item-h3 for laptop, table and phone screen resolutions  -->\n      @for (item of tableOfContentItems(); track item.id) {\n        <li\n          class=\"docs-faceted-list-item\"\n          [class.docs-toc-item-h2]=\"item.level === TableOfContentsLevel.H2\"\n          [class.docs-toc-item-h3]=\"item.level === TableOfContentsLevel.H3\"\n        >\n          <!-- Not using routerLink + fragment because of: https://github.com/angular/angular/issues/30139 -->\n          <a\n            [href]=\"location.path() + '#' + item.id\"\n            [class.docs-faceted-list-item-active]=\"item.id === activeItemId()\"\n            [title]=\"item.title\"\n          >\n            {{ item.title }}\n          </a>\n        </li>\n      }\n    </ul>","source":"v4-html-angular-angular-adev-shared-docs-components-table-of-contents-table-of-contents-component-html-6-24-0031","language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"hard","score":11}
{"text":"<section class=\"performance-section\" id=\"performance\">\n    <div class=\"wrapper\">\n      <div class=\"pattern\"></div>\n      <div class=\"content\">\n        <h2>Where performance matters</h2>\n        <h3>\n          Trusted by millions to build fast, reliable applications that scale with the size of your\n          team\n        </h3>\n        <button\n          class=\"docs-primary-btn\"\n          [attr.text]=\"'Get started'\"\n          routerLink=\"/guide/performance\"\n        >\n          <!-- TODO: LINK -->\n          Get started\n        </button>\n      </div>\n    </div>\n  </section>","source":"v4-html-angular-angular-adev-src-app-features-home-home-component-html-140-159-0145","language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"hard","score":10}
{"text":"<mat-panel-title>\n          <div class=\"node-header\">\n            <button\n              class=\"component-name\"\n              (click)=\"expanded.set(!expanded())\"\n              [class.expanded]=\"expanded()\"\n            >\n              <span>{{ comp.name }}</span>\n              <mat-icon> keyboard_arrow_down </mat-icon>\n            </button>\n            @if (signalGraphEnabled()) {\n              <button\n                ng-button\n                type=\"button\"\n                class=\"signal-btn\"\n                size=\"compact\"\n                (click)=\"showSignalGraph.emit()\"\n              >\n                Show Signal Graph\n              </button>\n            }\n          </div>\n        </mat-panel-title>","source":"v4-html-angular-angular-devtools-projects-ng-devtools-src-lib-devtools-tabs-directive-explorer-property-pane-property-pane-header-property-pane-header-component-html-6-28-0226","language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"hard","score":10}
{"text":"<mat-expansion-panel-header collapsedHeight=\"2.5rem\" expandedHeight=\"2.5rem\">\n      <div class=\"dep-data\">\n        <div class=\"dep-pill\" matTooltipPosition=\"left\" matTooltip=\"Dependency injection token\">\n          {{ dependency().token }}\n        </div>\n        @if (dependency().flags?.optional) {\n          <div class=\"dep-pill flagged\">Optional</div>\n        }\n        @if (dependency().flags?.host) {\n          <div class=\"dep-pill flagged\">Host</div>\n        }\n        @if (dependency().flags?.self) {\n          <div class=\"dep-pill flagged\">Self</div>\n        }\n        @if (dependency().flags?.skipSelf) {\n          <div class=\"dep-pill flagged\">SkipSelf</div>\n        }\n      </div>\n    </mat-expansion-panel-header>","source":"v4-html-angular-angular-devtools-projects-ng-devtools-src-lib-devtools-tabs-directive-explorer-property-pane-property-view-property-view-body-dependency-viewer-dependency-viewer-component-html-3-21-0231","language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"hard","score":10}
{"text":"<ng-template ngMenuContent>\n        @if (availableActions.showSignalGraph) {\n          <button\n            ngMenuItem\n            value=\"graph\"\n            class=\"ng-ctx-menu-item\"\n            (click)=\"showInSignalGraph($event)\"\n          >\n            <mat-icon>graph_2</mat-icon>\n            <span>Show in signal graph</span>\n          </button>\n        }\n\n        @if (availableActions.logToConsole) {\n          <button ngMenuItem value=\"log\" class=\"ng-ctx-menu-item\" (click)=\"logValue($event)\">\n            <mat-icon>terminal</mat-icon>\n            <span>Log to console</span>\n          </button>\n        }\n      </ng-template>","source":"v4-html-angular-angular-devtools-projects-ng-devtools-src-lib-devtools-tabs-directive-explorer-property-pane-property-view-property-view-body-prop-actions-menu-prop-actions-menu-component-html-63-82-0235","language":"html","framework":"general","project":"keyloop-corpus","level":"function","difficulty":"hard","score":9}
