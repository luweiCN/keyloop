{"text":"{{- define \"main\" }}\n\n{{- if .Title }}\n<header class=\"page-header\">\n    <h1>{{ .Title }}</h1>\n    {{- if .Description }}\n    <div class=\"post-description\">\n        {{ .Description }}\n    </div>\n    {{- end }}\n</header>\n{{- end }}\n\n<ul class=\"terms-tags\">\n    {{- $type := .Type }}\n        {{- range $key, $value := .Data.Terms.Alphabetical }}\n            {{- $name := .Name }}\n            {{- $count := .Count }}\n            {{- with site.GetPage (printf \"/%s/%s\" $type $name) }}\n            <li>\n                <a href=\"{{ .Permalink }}\">{{ .LinkTitle }} <sup><strong><sup>{{ $count }}</sup></strong></sup> </a>\n            </li>\n        {{- end }}\n    {{- end }}\n</ul>\n\n{{- end }}{{/* end main */ -}}","source":"v3-html-adityatelange--hugo-PaperMod-0030","language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"hard","score":11}
{"text":"{{- with or .Params.locale site.Language.LanguageCode }}\n  <meta property=\"og:locale\" content=\"{{ replace . `-` `_` }}\">\n{{- end }}\n\n{{- if .IsPage }}\n  <meta property=\"og:type\" content=\"article\">\n  {{- with .Section }}\n    <meta property=\"article:section\" content=\"{{ . }}\">\n  {{- end }}\n  {{- $ISO8601 := \"2006-01-02T15:04:05-07:00\" }}\n  {{- with .PublishDate }}\n    <meta property=\"article:published_time\" {{ .Format $ISO8601 | printf \"content=%q\" | safeHTMLAttr }}>\n  {{- end }}\n  {{- with .Lastmod }}\n    <meta property=\"article:modified_time\" {{ .Format $ISO8601 | printf \"content=%q\" | safeHTMLAttr }}>\n  {{- end }}\n  {{- range .GetTerms \"tags\" | first 6 }}\n    <meta property=\"article:tag\" content=\"{{ .Page.Title | plainify }}\">\n  {{- end }}\n{{- else }}\n  <meta property=\"og:type\" content=\"website\">","source":"v3-html-adityatelange--hugo-PaperMod-0032","language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"hard","score":9}
{"text":"{{- range $pages.GroupByPublishDate \"2006\" }}\n{{- if ne .Key \"0001\" }}\n<div class=\"archive-year\">\n  {{- $year := replace .Key \"0001\" \"\" }}\n  <h2 class=\"archive-year-header\" id=\"{{ $year }}\">\n    <a class=\"archive-header-link\" href=\"#{{ $year }}\">\n      {{- $year -}}\n    </a>\n    <sup class=\"archive-count\">&nbsp;{{ len .Pages }}</sup>\n  </h2>\n  {{- range .Pages.GroupByDate \"January\" }}\n  <div class=\"archive-month\">\n    <h3 class=\"archive-month-header\" id=\"{{ $year }}-{{ .Key }}\">\n      <a class=\"archive-header-link\" href=\"#{{ $year }}-{{ .Key }}\">\n        {{- .Key -}}\n      </a>\n      <sup class=\"archive-count\">&nbsp;{{ len .Pages }}</sup>\n    </h3>\n    <div class=\"archive-posts\">\n      {{- range .Pages }}\n      {{- if eq .Kind \"page\" }}\n      <div class=\"archive-entry\">\n        <h3 class=\"archive-entry-title entry-hint-parent\">\n          {{- .Title | markdownify }}\n          {{- if .Draft }}","source":"v3-html-adityatelange--hugo-PaperMod-0048","language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"hard","score":12}
