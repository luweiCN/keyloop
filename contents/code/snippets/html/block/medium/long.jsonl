{"text":"<div\n    class=\"docs-nav-secondary docs-scroll-track-transparent\"\n    [style.transform]=\"translateX()\"\n    [style.transition]=\"transition()\"\n  >\n    <!-- Secondary Nav -->\n    @if (navigationItems && navigationItems.length > 0) {\n      <docs-navigation-list\n        [navigationItems]=\"navigationItems\"\n        [displayItemsToLevel]=\"maxVisibleLevelsOnSecondaryNav()\"\n        [expandableLevel]=\"maxVisibleLevelsOnSecondaryNav()\"\n        [preserveOtherCategoryOrder]=\"true\"\n        (linkClicked)=\"close()\"\n      />\n    }\n\n    <!-- Third, fourth and next levels of navigation -->\n    @for (item of navigationItemsSlides(); track item; let level = $index) {\n      <docs-navigation-list\n        [collapsableLevel]=\"level + maxVisibleLevelsOnSecondaryNav()\"\n        [expandableLevel]=\"level + maxVisibleLevelsOnSecondaryNav() + 1\"\n        [navigationItems]=\"[item]\"\n        [preserveOtherCategoryOrder]=\"item.preserveOtherCategoryOrder ?? false\"\n        [displayItemsToLevel]=\"level + maxVisibleLevelsOnSecondaryNav() + 1\"\n        (linkClicked)=\"close()\"\n      />\n    }\n  </div>","source":"v4-html-angular-angular-adev-src-app-core-layout-secondary-navigation-secondary-navigation-component-html-8-35-0056","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":9}
{"text":"<div class=\"adev-preview-error docs-light-mode docs-mini-scroll-track\">\n  @if (error()?.type === ErrorType.UNSUPPORTED_BROWSER_ENVIRONMENT) {\n    @if (isIos) {\n      <p>Open angular.dev on desktop to code in your browser.</p>\n    }\n  } @else if (error()?.type === ErrorType.COOKIES || error()?.type === ErrorType.UNKNOWN) {\n    <p>\n      We couldn't start the tutorial app. Please ensure third party cookies are enabled for this\n      site.\n    </p>\n  } @else if (error()?.type === ErrorType.OUT_OF_MEMORY) {\n    <p>\n      We couldn't start the tutorial app because your browser is out of memory. To free up memory,\n      close angular.dev tutorials in other tabs or windows, and refresh the page.\n    </p>\n  }\n\n  @if (error()?.message) {\n    <small>\n      The error message is:\n      <code>{{ error()!.message }}</code>\n    </small>\n  }\n</div>","source":"v4-html-angular-angular-adev-src-app-editor-preview-preview-error-component-html-1-24-0071","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":9}
{"text":"<div class=\"adev-embedded-editor-preview-loading\">\n      @switch (loadingProgressValue()) {\n        @case (loadingEnum.NOT_STARTED) {\n          <span class=\"adev-embedded-editor-preview-loading-starting\">Starting</span>\n        }\n        @case (loadingEnum.BOOT) {\n          <span class=\"adev-embedded-editor-preview-loading-boot\">Booting</span>\n        }\n        @case (loadingEnum.LOAD_FILES) {\n          <span class=\"adev-embedded-editor-preview-loading-load-files\">Creating project</span>\n        }\n        @case (loadingEnum.INSTALL) {\n          <span class=\"adev-embedded-editor-preview-loading-install\">Installing packages</span>\n        }\n        @case (loadingEnum.START_DEV_SERVER) {\n          <span class=\"adev-embedded-editor-preview-loading-start-dev-server\">\n            Initializing dev server\n          </span>\n        }\n      }\n      <progress\n        title=\"Preview progress\"\n        [value]=\"loadingProgressValue()\"\n        [max]=\"loadingEnum.READY\"\n      ></progress>\n    </div>","source":"v4-html-angular-angular-adev-src-app-editor-preview-preview-component-html-14-39-0073","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":9}
