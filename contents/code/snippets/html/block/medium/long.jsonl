{"text":"<div class=\"config-controls\">\n            <div class=\"control-group\">\n              <div class=\"label-row\">\n                <label>Network Latency</label>\n                <span class=\"latency-value font-mono\">{{ latency() }}ms</span>\n              </div>\n              <input\n                type=\"range\"\n                min=\"0\"\n                max=\"4000\"\n                step=\"100\"\n                [value]=\"latency()\"\n                (input)=\"updateLatency($event)\"\n                class=\"range-input\"\n              />\n            </div>\n\n            <button\n              (click)=\"resetSimulation()\"\n              [disabled]=\"isSimulationRunning()\"\n              class=\"btn-reset\"\n            >\n              <docs-icon>refresh</docs-icon>\n              Reset Lifecycle\n            </button>\n          </div>","source":"v4-html-angular-angular-adev-src-app-features-home-components-hydration-example-hydration-example-html-22-47-0087","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":10}
{"text":"<div class=\"card-top\">\n                      <div\n                        class=\"icon-box transition-all\"\n                        [class]=\"card.isHydrated ? 'icon-hydrated' : 'icon-static'\"\n                      >\n                        @if (card.isHydrating) {\n                          <div class=\"loading-spinner\"></div>\n                        } @else {\n                          <docs-icon>water_drop</docs-icon>\n                        }\n                      </div>\n                      @if (card.clickCount > 0) {\n                        <div class=\"click-badge font-tabular animate-zoom\">\n                          <span class=\"badge-label\">CLICKS:</span> {{ card.clickCount }}\n                        </div>\n                      }\n                    </div>","source":"v4-html-angular-angular-adev-src-app-features-home-components-hydration-example-hydration-example-html-120-136-0102","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":10}
