{"text":"<div class=\"controls\">\n  @if (visualizationMode() === VisMode.FlameGraph) {\n    <input\n      id=\"cd-only-checkbox\"\n      type=\"checkbox\"\n      [checked]=\"changeDetection()\"\n      (change)=\"changeDetection.set($any($event.target).checked)\"\n    />\n    <label for=\"cd-only-checkbox\"> Show only change detection </label>\n    <div class=\"ver-ruler\"></div>\n  }\n\n  <select #select (change)=\"onVisualizationChange(select.value)\" class=\"ng-select size-mid\">\n    <option [value]=\"VisMode.FlameGraph\" [selected]=\"visualizationMode() === VisMode.FlameGraph\">\n      Flame graph\n    </option>\n    <option [value]=\"VisMode.TreeMap\" [selected]=\"visualizationMode() === VisMode.TreeMap\">\n      Tree map\n    </option>\n    <option [value]=\"VisMode.BarGraph\" [selected]=\"visualizationMode() === VisMode.BarGraph\">\n      Bar chart\n    </option>\n  </select>\n</div>","source":"v4-html-angular-angular-devtools-projects-ng-devtools-src-lib-devtools-tabs-profiler-recording-timeline-visualizer-controls-visualizer-controls-component-html-19-42-0272","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":10}
{"text":"<div class=\"action-buttons\">\n                  @if (isValueLong(valuePreview, item.isExpanded)) {\n                    <button\n                      ng-button\n                      btnType=\"icon\"\n                      size=\"compact\"\n                      class=\"expand-button\"\n                      (click)=\"toggleExpanded(item)\"\n                      [matTooltip]=\"item.isExpanded ? 'Collapse value' : 'Expand value'\"\n                    >\n                      <mat-icon>{{ item.isExpanded ? 'expand_less' : 'expand_more' }}</mat-icon>\n                    </button>\n                  }\n                  <button\n                    ng-button\n                    btnType=\"icon\"\n                    size=\"compact\"\n                    class=\"copy-button\"\n                    (click)=\"copyToClipboard(item)\"\n                    [matTooltip]=\"item.isCopied ? 'Copied!' : 'Copy value to clipboard'\"\n                  >\n                    <mat-icon>{{ item.isCopied ? 'check' : 'content_copy' }}</mat-icon>\n                  </button>\n                </div>","source":"v4-html-angular-angular-devtools-projects-ng-devtools-src-lib-devtools-tabs-transfer-state-transfer-state-component-html-98-121-0289","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":10}
{"text":"<div class=\"prop-row non-expandable-node\">\n      @if (!omitRootNodesNames() || node.level > 0) {\n        <span class=\"name\">{{ node.prop.name }}</span\n        >:\n      }\n      @if (!node.prop.descriptor.editable || !editingEnabled()) {\n        <ng-property-preview class=\"value\" (inspect)=\"propInspect.emit(node)\" [node]=\"node\" />\n      } @else {\n        <ng-property-editor\n          class=\"value\"\n          [property]=\"node.prop\"\n          (updateValue)=\"propValueUpdate.emit({node, newValue: $event})\"\n        />\n      }\n      @if (contentTemplateRef(); as contentTemplateRef) {\n        <ng-container\n          [ngTemplateOutlet]=\"contentTemplateRef\"\n          [ngTemplateOutletContext]=\"{$implicit: node}\"\n        />\n      }\n    </div>","source":"v4-html-angular-angular-devtools-projects-ng-devtools-src-lib-shared-object-tree-explorer-object-tree-explorer-component-html-13-33-0298","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":10}
{"text":"<div class=\"search\">\n      <ng-filter\n        (filter)=\"handleFilter($event)\"\n        (nextMatched)=\"navigateMatchedNode('next')\"\n        (prevMatched)=\"navigateMatchedNode('prev')\"\n        [matchesCount]=\"searchMatches().length\"\n        [currentMatch]=\"currentSearchMatchIdx() + 1\"\n        [filterFnGenerator]=\"filterGenerator\"\n        placeholder=\"Search node\"\n        [debounce]=\"250\"\n      />\n      <div class=\"search-btn\" [matTooltip]=\"FILTER_INFO_TOOLTIP\">\n        <mat-icon>info</mat-icon>\n      </div>\n      <button\n        ng-button\n        btnType=\"icon\"\n        class=\"search-btn close-search\"\n        (click)=\"searchExpanded.set(false)\"\n        matTooltip=\"Close search box\"\n        aria-label=\"Close search box\"\n      >\n        <mat-icon>close</mat-icon>\n      </button>\n    </div>","source":"v4-html-angular-angular-devtools-projects-ng-devtools-src-lib-shared-signals-visualizer-signals-visualizer-component-html-18-42-0302","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":9}
{"text":"<template>\n  <el-row :gutter=\"12\">\n    <el-col :span=\"10\" :xs=\"{ span: 12 }\">\n      <div class=\"demo-color-box\" :style=\"{ background: primary }\">\n        Brand Color\n        <div class=\"value\" text=\"xs\">{{ primary.toUpperCase() }}</div>\n        <div class=\"bg-color-sub\" :style=\"{ background: primary }\">\n          <div\n            v-for=\"level in colorLevel\"\n            :key=\"level\"\n            class=\"bg-blue-sub-item cursor-pointer hover:shadow\"\n            :style=\"{\n              width: `${100 / 6}%`,\n              background: 'var(--el-color-primary-' + level + ')',\n            }\"\n            @click=\"copyColor('primary-' + level)\"\n          />\n        </div>\n      </div>\n    </el-col>\n  </el-row>\n</template>","source":"v4-html-element-plus-element-plus-docs-vitepress-vitepress-components-globals-main-color-vue-12-33-0020","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":10}
{"text":"<ElCard v-if=\"currentRelease\">\n          <template #header>\n            <div class=\"changelog-header\">\n              <div class=\"changelog-meta\">\n                <p class=\"changelog-by\">\n                  {{ changelog['published-by'] }}\n                  <strong>{{ currentRelease.author.login }}</strong>\n                </p>\n                <p class=\"changelog-date\">\n                  {{\n                    new Date(currentRelease.published_at).toLocaleString(lang)\n                  }}\n                </p>\n              </div>\n              <div class=\"operators\">\n                <VPLink :href=\"currentRelease.html_url\">\n                  {{ changelog['open-link'] }}\n                </VPLink>\n              </div>\n            </div>\n          </template>\n          <div>\n            <VPMarkdown :content=\"currentRelease.body\" />\n          </div>\n        </ElCard>","source":"v4-html-element-plus-element-plus-docs-vitepress-vitepress-components-globals-vp-changelog-vue-69-93-0037","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":10}
