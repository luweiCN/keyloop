{"text":"<a\n                [href]=\"item.path\"\n                target=\"_blank\"\n                [matTooltip]=\"item.label\"\n                [matTooltipDisabled]=\"itemLabel.length < labelTruncationThreshold\"\n                matTooltipPosition=\"after\"\n                [attr.aria-label]=\"item.label\"\n                [matTooltipClass]=\"'API-tooltip'\"\n              >\n                <span\n                  [class.docs-external-link]=\"item.isExternal\"\n                  class=\"docs-faceted-list-item-text\"\n                >\n                  {{ item.label }}\n                </span>\n\n                @if (item.children && item.level! > 1 && !item.isExpanded) {\n                  <docs-icon>chevron_right</docs-icon>\n                }\n              </a>","source":"v4-html-angular-angular-adev-shared-docs-components-navigation-list-navigation-list-component-html-26-45-0001","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"block","difficulty":"medium","score":10}
