{"text":"<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport _contributors from '@element-plus/metadata/dist/contributors.json'\nimport VpLink from '../common/vp-link.vue'\n\nconst props = defineProps<{ id: string }>()\n\nconst contributors = computed(() =>\n  _contributors[props.id]?.filter((c) => c.login !== 'renovate[bot]')\n)\n\nconst withSize = (rawURL: string) => {\n  return `${rawURL}${rawURL.includes('?') ? '&' : '?'}size=64`\n}\n</script>\n\n<template>\n  <div class=\"flex flex-wrap gap-2 pb-2\">\n    <el-tooltip\n      v-for=\"{ login, avatar, name, hash } of contributors\"\n      :key=\"hash\"\n      :content=\"name\"\n      placement=\"top\"\n    >\n      <vp-link\n        :href=\"`https://github.com/${login}`\"\n        class=\"flex gap-2 items-center link\"\n        no-icon\n      >\n        <img\n          :src=\"withSize(avatar)\"\n          class=\"w-8 h-8 rounded-full\"\n          loading=\"lazy\"\n        />\n      </vp-link>\n    </el-tooltip>\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n.link {\n  color: var(--text-color-light);\n\n  &:hover {\n    color: var(--brand-color);\n  }\n}\n</style>","source":"v4-html-element-plus-element-plus-docs-vitepress-vitepress-components-globals-contributors-vue-1-49-0010","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<template>\n  <svg\n    id=\"图层_1\"\n    version=\"1.1\"\n    xmlns=\"http://www.w3.org/2000/svg\"\n    xmlns:xlink=\"http://www.w3.org/1999/xlink\"\n    x=\"0px\"\n    y=\"0px\"\n    viewBox=\"0 0 79 79\"\n    style=\"enable-background: new 0 0 79 79\"\n    xml:space=\"preserve\"\n  >\n    <circle class=\"st0\" cx=\"39.5\" cy=\"39.5\" r=\"39.5\" />\n    <path\n      class=\"st1\"\n      d=\"M19.8,26.2c0-3.3,2.7-5.9,5.9-5.9h27.7c3.3,0,5.9,2.7,5.9,5.9v23.7c0,3.3-2.7,5.9-5.9,5.9H25.9l-6.2,6.4V26.2z\"\n    />\n    <path\n      class=\"st2\"\n      d=\"M19.8,24.2c0-3.3,2.7-5.9,5.9-5.9h27.7c3.3,0,5.9,2.7,5.9,5.9v23.7c0,3.3-2.7,5.9-5.9,5.9H25.9l-6.2,6.4V24.2z\"\n    />\n    <path\n      class=\"st3\"\n      d=\"M37.5,35.5c0-1.1,0.9-2,2-2s2,0.9,2,2v7.9c0,1.1-0.9,2-2,2s-2-0.9-2-2V35.5z\"\n    />\n    <path\n      class=\"st3\"\n      d=\"M37.5,29.1c0-1.1,0.9-2,2-2s2,0.9,2,2c0,1.1-0.9,2-2,2S37.5,30.2,37.5,29.1z\"\n    />\n  </svg>\n</template>\n\n<style scoped lang=\"scss\">\n.st0 {\n  fill: #eff5fd;\n}\n.st1 {\n  fill: #0077ce;\n}\n.st2 {\n  fill: #20a0ff;\n}\n.st3 {\n  fill: #ffffff;\n}\n\n.dark {\n  .st0 {\n    fill: #36393d;\n  }\n}\n</style>","source":"v4-html-element-plus-element-plus-docs-vitepress-vitepress-components-globals-design-feedback-svg-vue-1-53-0017","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script lang=\"ts\" setup>\nimport { getColorValue, useCopyColor } from '../../utils'\n\nconst colorsType = ['success', 'warning', 'danger', 'info']\n\nconst colorLevel = [3, 5, 7, 8, 9].map((item) => `light-${item}`)\ncolorLevel.unshift('dark-2')\n\nconst { copyColor } = useCopyColor()\n</script>\n\n<template>\n  <el-row :gutter=\"12\">\n    <el-col\n      v-for=\"(type, i) in colorsType\"\n      :key=\"i\"\n      :span=\"6\"\n      :xs=\"{ span: 12 }\"\n    >\n      <div class=\"demo-color-box\" :style=\"{ background: getColorValue(type) }\">\n        {{ type.charAt(0).toUpperCase() + type.slice(1) }}\n        <div class=\"value\" text=\"xs\">\n          {{ getColorValue(type).toUpperCase() }}\n        </div>\n        <div class=\"bg-color-sub\">\n          <div\n            v-for=\"(level, key) in colorLevel\"\n            :key=\"key\"\n            class=\"bg-secondary-sub-item transition cursor-pointer hover:shadow\"\n            :style=\"{\n              width: `${100 / 6}%`,\n              background: `var(--el-color-${type}-` + level + ')',\n            }\"\n            @click=\"copyColor(type + '-' + level)\"\n          />\n        </div>\n      </div>\n    </el-col>\n  </el-row>\n</template>","source":"v4-html-element-plus-element-plus-docs-vitepress-vitepress-components-globals-secondary-colors-vue-1-41-0032","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { Warning } from '@element-plus/icons-vue'\nimport { useLang } from '../../composables/lang'\nimport apiTypingLocale from '../../../i18n/component/api-typing.json'\n\ndefineProps({\n  type: String,\n  details: String,\n})\n\nconst lang = useLang()\nconst detail = computed(() => apiTypingLocale[lang.value].detail)\n</script>\n\n<template>\n  <span class=\"inline-flex items-center\">\n    <code class=\"api-typing mr-1\">\n      {{ type }}\n    </code>\n    <ClientOnly>\n      <ElTooltip v-if=\"details\" effect=\"light\" trigger=\"click\">\n        <ElButton\n          text\n          :icon=\"Warning\"\n          :aria-label=\"detail\"\n          class=\"p-2 text-4\"\n        />\n        <template #content>\n          <slot>\n            <div class=\"m-1\" style=\"max-width: 600px\">\n              <code\n                style=\"\n                  color: var(--code-tooltip-color);\n                  background-color: var(--code-tooltip-bg-color);\n                \"\n              >\n                {{ details }}\n              </code>\n            </div>\n          </slot>\n        </template>\n      </ElTooltip>\n    </ClientOnly>\n  </span>\n</template>","source":"v4-html-element-plus-element-plus-docs-vitepress-vitepress-components-globals-vp-api-typing-vue-1-47-0036","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
