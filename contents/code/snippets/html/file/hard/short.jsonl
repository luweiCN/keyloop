{"text":"<div class=\"adev-playground-header\">\n  <header>\n    <h1 tabindex=\"-1\">Angular Playground</h1>\n  </header>\n  <div class=\"adev-template-select\">\n    <button type=\"button\" [cdkMenuTriggerFor]=\"templatesMenu\">\n      <span>{{ selectedTemplate.label }}</span>\n      <docs-icon>expand_more</docs-icon>\n    </button>\n  </div>\n</div>\n\n@if (embeddedEditorComponent()) {\n  <div class=\"adev-embedded-editor-wrapper\">\n    <ng-container *ngComponentOutlet=\"embeddedEditorComponent()\" />\n  </div>\n}\n\n<ng-template #templatesMenu>\n  <ul class=\"adev-template-dropdown\" cdkMenu>\n    @for (template of templates; track template.path) {\n      <li>\n        <button cdkMenuItem type=\"button\" (click)=\"changeTemplate(template)\">\n          <span>{{ template.label }}</span>\n        </button>\n      </li>\n    }\n  </ul>\n</ng-template>","source":"v4-html-angular-angular-adev-src-app-features-playground-playground-component-html-1-30-0158","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<form>\n  <div>\n    <label>\n      Email\n      <!-- TODO: Add [formField]=\"loginForm.email\" directive -->\n      <input type=\"email\" />\n    </label>\n  </div>\n\n  <div>\n    <label>\n      Password\n      <!-- TODO: Add [formField]=\"loginForm.password\" directive -->\n      <input type=\"password\" />\n    </label>\n  </div>\n\n  <div>\n    <label>\n      <!-- TODO: Add [formField]=\"loginForm.rememberMe\" directive -->\n      <input type=\"checkbox\" />\n      Remember me\n    </label>\n  </div>\n\n  <button type=\"submit\">Log in</button>\n</form>\n\n<div class=\"form-debug\">\n  <h3>Current Form Values:</h3>\n  <!-- TODO: Display loginForm.email().value() -->\n  <p>Email:</p>\n  <!-- TODO: Display loginForm.password().value() with masking -->\n  <p>Password:</p>\n  <!-- TODO: Display loginForm.rememberMe().value() as Yes/No -->\n  <p>Remember me:</p>\n</div>","source":"v4-html-angular-angular-adev-src-content-tutorials-signal-forms-steps-2-connect-form-template-src-app-app-html-1-38-0201","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<form>\n  <div>\n    <label>\n      Email\n      <input type=\"email\" [formField]=\"loginForm.email\" />\n    </label>\n    @if (loginForm.email().invalid() && loginForm.email().touched()) {\n      <div class=\"error\">\n        @for (error of loginForm.email().errors(); track error.kind) {\n          <span>{{ error.message }}</span>\n        }\n      </div>\n    }\n  </div>\n\n  <div>\n    <label>\n      Password\n      <input type=\"password\" [formField]=\"loginForm.password\" />\n    </label>\n    @if (loginForm.password().invalid() && loginForm.password().touched()) {\n      <div class=\"error\">\n        @for (error of loginForm.password().errors(); track error.kind) {\n          <span>{{ error.message }}</span>\n        }\n      </div>\n    }\n  </div>\n\n  <div>\n    <label>\n      <input type=\"checkbox\" [formField]=\"loginForm.rememberMe\" />\n      Remember me\n    </label>\n  </div>\n\n  <button type=\"submit\">Log in</button>\n</form>\n\n<div class=\"form-debug\">\n  <h3>Current Form Values:</h3>\n  <p>Email: {{ loginForm.email().value() }}</p>\n  <p>Password: {{ loginForm.password().value() ? '••••••••' : '(empty)' }}</p>\n  <p>Remember me: {{ loginForm.rememberMe().value() ? 'Yes' : 'No' }}</p>\n</div>","source":"v4-html-angular-angular-adev-src-content-tutorials-signal-forms-steps-4-display-errors-answer-src-app-app-html-1-46-0202","language":"html","syntax_language":"html","framework":"general","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
