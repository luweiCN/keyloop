{"text":"<script setup lang=\"ts\">\nimport { withBase } from 'vitepress'\nimport { rightBigLogoSponsors } from '../../../config/sponsors'\nimport { sendEvent } from '../../../config/analytics'\nimport { isDark } from '../../composables/dark'\n\nimport type { Sponsor } from '../../../config/sponsors'\n\nconst onItemClick = (item: Sponsor) => {\n  sendEvent('sp_click', item.name, 'right_richtext_list')\n}\n</script>\n\n<template>\n  <div class=\"right-big\">\n    <a\n      v-for=\"item in rightBigLogoSponsors\"\n      :key=\"item.name\"\n      :href=\"withBase(item.url)\"\n      :title=\"`${item.name_cn || item.name} - ${item.slogan_cn || item.slogan}`\"\n      target=\"_blank\"\n      @click=\"onItemClick(item)\"\n    >\n      <div\n        :class=\"[\n          isDark && '!bg-#262729',\n          'flex bg-#F9F9F9 h-64px rd-4px justify-center items-center',\n        ]\"\n      >\n        <div class=\"h-36px\">\n          <img\n            class=\"rd-4px h-full\"\n            :src=\"withBase(item.imgL ?? '')\"\n            :alt=\"item.name\"\n          />\n        </div>\n      </div>\n    </a>\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n.right-big {\n  margin-top: 16px;\n}\n</style>","source":"v4-html-element-plus-element-plus-docs-vitepress-vitepress-components-sponsors-right-big-logo-list-vue-1-47-0080","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"file","difficulty":"hard","score":12}
