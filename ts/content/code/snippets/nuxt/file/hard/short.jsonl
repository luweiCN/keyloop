{"text":"<script setup lang=\"ts\">\nimport type { NavigationMenuItem, SidebarProps } from '@nuxt/ui'\n\n// Ignore the props for the example\ndefineProps<Pick<SidebarProps, 'mode'>>()\n\nconst open = ref(true)\n\nconst items: NavigationMenuItem[] = [{\n  label: 'Home',\n  icon: 'i-lucide-house',\n  active: true\n}, {\n  label: 'Inbox',\n  icon: 'i-lucide-inbox',\n  badge: '4'\n}, {\n  label: 'Contacts',\n  icon: 'i-lucide-users'\n}]\n</script>\n\n<template>\n  <div class=\"flex flex-1\">\n    <USidebar v-model:open=\"open\" :mode=\"mode\" title=\"Navigation\">\n      <UNavigationMenu\n        :items=\"items\"\n        orientation=\"vertical\"\n        :ui=\"{ link: 'p-1.5 overflow-hidden' }\"\n      />\n    </USidebar>\n\n    <div class=\"flex-1 flex flex-col\">\n      <div class=\"h-(--ui-header-height) shrink-0 flex items-center px-4 border-b border-default\">\n        <UButton\n          icon=\"i-lucide-panel-left\"\n          color=\"neutral\"\n          variant=\"ghost\"\n          aria-label=\"Toggle sidebar\"\n          @click=\"open = !open\"\n        />\n      </div>\n\n      <div class=\"flex-1 p-4\">\n        <Placeholder class=\"size-full\" />\n      </div>\n    </div>\n  </div>\n</template>","source":"v4-nuxt-nuxt-ui-docs-app-components-content-examples-sidebar-sidebarmodeexample-vue-1-49-0951-0279","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script setup lang=\"ts\">\nimport type { NavigationMenuItem } from '@nuxt/ui'\n\nconst open = ref(true)\n\ndefineShortcuts({\n  o: () => open.value = !open.value\n})\n\nconst items: NavigationMenuItem[] = [{\n  label: 'Home',\n  icon: 'i-lucide-house',\n  active: true\n}, {\n  label: 'Inbox',\n  icon: 'i-lucide-inbox',\n  badge: '4'\n}, {\n  label: 'Contacts',\n  icon: 'i-lucide-users'\n}]\n</script>\n\n<template>\n  <div class=\"flex flex-1\">\n    <USidebar v-model:open=\"open\" title=\"Navigation\" collapsible=\"icon\">\n      <UNavigationMenu\n        :items=\"items\"\n        orientation=\"vertical\"\n        :ui=\"{ link: 'p-1.5 overflow-hidden' }\"\n      />\n    </USidebar>\n\n    <div class=\"flex-1 flex flex-col\">\n      <div class=\"h-(--ui-header-height) shrink-0 flex items-center px-4 border-b border-default\">\n        <UButton\n          icon=\"i-lucide-panel-left\"\n          color=\"neutral\"\n          variant=\"ghost\"\n          :aria-label=\"open ? 'Close sidebar' : 'Open sidebar'\"\n          @click=\"open = !open\"\n        />\n      </div>\n\n      <div class=\"flex-1 p-4\">\n        <Placeholder class=\"size-full\" />\n      </div>\n    </div>\n  </div>\n</template>","source":"v4-nuxt-nuxt-ui-docs-app-components-content-examples-sidebar-sidebaropenexample-vue-1-50-0952-0280","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script lang=\"ts\" setup>\nconst route = useRoute();\nconst key = ref(route.path);\n\nfunction attachRouteWatcher() {\n  watch(\n    () => route.path,\n    (newPath) => {\n      key.value = newPath;\n    },\n  );\n}\n</script>\n\n<template>\n  <div>\n    <ClientOnly>\n      <ScriptCarbonAds\n        @ready=\"attachRouteWatcher\"\n        :key=\"key\"\n        format=\"cover\"\n        serve=\"CW7I5KQN\"\n        placement=\"i18nnuxtjsorg\"\n        trigger=\"onNuxtReady\"\n      >\n        <template #error>\n          <AdsFallback />\n        </template>\n      </ScriptCarbonAds>\n    </ClientOnly>\n  </div>\n</template>\n\n<style>\n.dark #carbon-responsive {\n  --carbon-padding: 1em;\n  --carbon-max-char: 20ch;\n  --carbon-bg-primary: var(--ui-bg);\n  --carbon-bg-secondary: var(--ui-bg-muted);\n  --carbon-text-color: var(--ui-text);\n}\n\n#carbon-responsive .carbon-responsive-wrap {\n  border-radius: var(--ui-radius);\n}\n</style>","source":"v4-nuxt-nuxt-modules-i18n-docs-app-components-ads-vue-1-46-0273-0260","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script setup lang=\"ts\">\nconst route = useRoute();\nconst links = computed(() => [\n  {\n    label: \"Docs\",\n    to: \"/docs/getting-started\",\n    icon: \"i-lucide-book-open\",\n    active: route.path.startsWith(\"/docs\"),\n  },\n]);\n</script>\n\n<template>\n  <UHeader\n    :ui=\"{\n      left: 'min-w-0',\n    }\"\n    class=\"flex flex-col\"\n  >\n    <template #left>\n      <AppHeaderLogo />\n    </template>\n\n    <UNavigationMenu :items=\"links\" variant=\"link\" />\n\n    <template #right>\n      <UTooltip text=\"Search\" :kbds=\"['meta', 'K']\">\n        <UContentSearchButton />\n      </UTooltip>\n\n      <UColorModeButton class=\"hidden sm:flex\" />\n\n      <UTooltip text=\"Open on GitHub\" class=\"flex\">\n        <UButton\n          color=\"neutral\"\n          variant=\"ghost\"\n          to=\"https://github.com/nuxt-modules/i18n\"\n          target=\"_blank\"\n          icon=\"i-simple-icons-github\"\n          aria-label=\"GitHub\"\n        />\n      </UTooltip>\n    </template>\n\n    <template #body>\n      <UContentNavigation\n        :navigation=\"$currentDocsVersionNavigation.value\"\n        highlight\n        :ui=\"{ linkTrailingBadge: 'font-semibold uppercase' }\"\n      />\n    </template>\n  </UHeader>\n</template>","source":"v4-nuxt-nuxt-modules-i18n-docs-app-components-appheader-vue-1-53-0275-0261","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"import { defineNuxtPlugin, useNuxtApp } from '#imports'\nimport { useNuxtI18nContext } from '../context'\nimport { detectLocale } from '../utils'\n\nexport default defineNuxtPlugin({\n  name: 'i18n:plugin:ssg-detect',\n  dependsOn: !__I18N_PRELOAD__\n    ? ['i18n:plugin', 'i18n:plugin:route-locale-detect']\n    : ['i18n:plugin', 'i18n:plugin:route-locale-detect', 'i18n:plugin:preload'],\n  enforce: 'post',\n  setup(_nuxt) {\n    if (!__IS_SSG__ || !__I18N_ROUTING__) { return }\n\n    // @ts-expect-error untyped internal id parameter\n    const nuxt = useNuxtApp(_nuxt._id)\n    const ctx = useNuxtI18nContext(nuxt)\n    // NOTE: avoid hydration mismatch for SSG mode\n    nuxt.hook('app:mounted', async () => {\n      const detected = detectLocale(nuxt, nuxt.$router.currentRoute.value)\n      await nuxt.runWithContext(() => nuxt.$i18n.setLocale(detected))\n      ctx.initial = false\n    })\n  },\n})","source":"v4-nuxt-nuxt-modules-i18n-src-runtime-plugins-ssg-detect-ts-1-24-0108-0262","language":"nuxt","syntax_language":"typescript","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"import defaultTheme from 'tailwindcss/defaultTheme'\nimport type { Config } from 'tailwindcss'\n\nexport default <Partial<Config>>{\n  theme: {\n    extend: {\n      colors: {\n        slate: {\n          50: '#f8fafc',\n          100: '#f1f5f9',\n          200: '#e2e8f0',\n          300: '#cbd5e1',\n          400: '#94a3b8',\n          500: '#64748b',\n          600: '#475569',\n          700: '#334155',\n          800: '#1e293b',\n          900: '#0f172a',\n          950: '#020420',\n        },\n        green: {\n          50: '#EFFDF5',\n          100: '#D9FBE8',\n          200: '#B3F5D1',\n          300: '#75EDAE',\n          400: '#00DC82',\n          500: '#00C16A',\n          600: '#00A155',\n          700: '#007F45',\n          800: '#016538',\n          900: '#0A5331',\n          950: '#052e16',\n        },\n      },\n      fontFamily: {\n        sans: ['DM Sans', 'DM Sans fallback', ...defaultTheme.fontFamily.sans],\n      },\n    },\n  },\n}","source":"v4-nuxt-nuxt-modules-security-docs-tailwind-config-ts-1-40-0059-0263","language":"nuxt","syntax_language":"typescript","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"import { H3, type H3Event } from \"h3\";\nimport { runTask } from \"../task.ts\";\n\nimport { scheduledTasks, tasks } from \"#nitro/virtual/tasks\";\n\nconst taskHandler = async (event: H3Event) => {\n  const name = event.context.params?.name;\n  const body = (await event.req.json().catch(() => ({}))) as Record<string, unknown>;\n  const payload = {\n    ...Object.fromEntries(event.url.searchParams.entries()),\n    ...((body.payload as Record<string, unknown>) ?? body),\n  };\n  return await runTask(name!, {\n    context: { waitUntil: event.req.waitUntil },\n    payload,\n  });\n};\n\nconst app: H3 = new H3()\n  .get(\"/_nitro/tasks\", async () => {\n    const _tasks = await Promise.all(\n      Object.entries(tasks).map(async ([name, task]) => {\n        const _task = await task.resolve?.();\n        return [name, { description: _task?.meta?.description }];\n      })\n    );\n    return {\n      tasks: Object.fromEntries(_tasks),\n      scheduledTasks,\n    };\n  })\n  .get(\"/_nitro/tasks/:name\", taskHandler)\n  .post(\"/_nitro/tasks/:name\", taskHandler);\n\nexport default app;","source":"v4-nuxt-unjs-nitro-src-runtime-internal-routes-dev-tasks-ts-1-35-0136-0259","language":"nuxt","syntax_language":"typescript","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":12}
