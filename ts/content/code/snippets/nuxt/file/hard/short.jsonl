{"text":"<script setup lang=\"ts\">\nconst value = ref<File[]>([])\n</script>\n\n<template>\n  <UFileUpload\n    v-model=\"value\"\n    icon=\"i-lucide-image\"\n    label=\"Drop your images here\"\n    description=\"SVG, PNG, JPG or GIF (max. 2MB)\"\n    layout=\"grid\"\n    multiple\n    :interactive=\"false\"\n    class=\"w-96 min-h-48\"\n  >\n    <template #actions=\"{ open }\">\n      <UButton\n        label=\"Select images\"\n        icon=\"i-lucide-upload\"\n        color=\"neutral\"\n        variant=\"outline\"\n        @click=\"open()\"\n      />\n    </template>\n\n    <template #files-top=\"{ open, files }\">\n      <div v-if=\"files?.length\" class=\"mb-2 flex items-center justify-between\">\n        <p class=\"font-bold\">\n          Files ({{ files?.length }})\n        </p>\n\n        <UButton\n          icon=\"i-lucide-plus\"\n          label=\"Add more\"\n          color=\"neutral\"\n          variant=\"outline\"\n          class=\"-my-2\"\n          @click=\"open()\"\n        />\n      </div>\n    </template>\n  </UFileUpload>\n</template>","source":"v4-nuxt-nuxt-ui-docs-app-components-content-examples-file-upload-fileuploadfilestopslotexample-vue-1-43-0847-0258","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":12}
{"text":"<script setup lang=\"ts\">\nimport type { NavigationMenuItem } from '@nuxt/ui'\n\ndefineProps<{\n  mode: 'drawer' | 'slideover' | 'modal'\n}>()\n\nconst items: NavigationMenuItem[] = [{\n  label: 'Home',\n  icon: 'i-lucide-house',\n  active: true\n}, {\n  label: 'Inbox',\n  icon: 'i-lucide-inbox'\n}, {\n  label: 'Contacts',\n  icon: 'i-lucide-users'\n}]\n</script>\n\n<template>\n  <UDashboardGroup>\n    <UDashboardSidebar :mode=\"mode\">\n      <template #header=\"{ collapsed }\">\n        <Logo v-if=\"!collapsed\" class=\"h-5 w-auto\" />\n        <UIcon v-else name=\"i-simple-icons-nuxtdotjs\" class=\"size-5 text-primary mx-auto\" />\n      </template>\n\n      <UNavigationMenu\n        :items=\"items\"\n        orientation=\"vertical\"\n      />\n    </UDashboardSidebar>\n\n    <UDashboardPanel>\n      <template #header>\n        <UDashboardNavbar title=\"Dashboard\" />\n      </template>\n    </UDashboardPanel>\n  </UDashboardGroup>\n</template>","source":"v4-nuxt-nuxt-ui-docs-app-components-content-examples-dashboard-dashboardsidebarmodeexample-vue-1-41-0787-0274","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script setup lang=\"ts\">\nconst { data: countries, status, execute } = await useLazyFetch<{\n  name: string\n  code: string\n  emoji: string\n}[]>('/api/countries.json', {\n  key: 'api-countries',\n  immediate: false\n})\n\nfunction onOpen() {\n  if (!countries.value?.length) {\n    execute()\n  }\n}\n</script>\n\n<template>\n  <UInputMenu\n    :items=\"countries\"\n    :loading=\"status === 'pending'\"\n    label-key=\"name\"\n    :search-input=\"{ icon: 'i-lucide-search' }\"\n    placeholder=\"Select country\"\n    class=\"w-48\"\n    @update:open=\"onOpen\"\n  >\n    <template #leading=\"{ modelValue, ui }\">\n      <span v-if=\"modelValue\" class=\"size-5 text-center\">\n        {{ modelValue?.emoji }}\n      </span>\n      <UIcon v-else name=\"i-lucide-earth\" :class=\"ui.leadingIcon()\" />\n    </template>\n    <template #item-leading=\"{ item }\">\n      <span class=\"size-5 text-center\">\n        {{ item.emoji }}\n      </span>\n    </template>\n  </UInputMenu>\n</template>","source":"v4-nuxt-nuxt-ui-docs-app-components-content-examples-input-menu-inputmenucountriesexample-vue-1-40-0880-0275","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script setup lang=\"ts\">\nconst open = ref(false)\nconst anchor = ref({ x: 0, y: 0 })\n\nconst reference = computed(() => ({\n  getBoundingClientRect: () =>\n    ({\n      width: 0,\n      height: 0,\n      left: anchor.value.x,\n      right: anchor.value.x,\n      top: anchor.value.y,\n      bottom: anchor.value.y,\n      ...anchor.value\n    } as DOMRect)\n}))\n</script>\n\n<template>\n  <UPopover\n    :open=\"open\"\n    :reference=\"reference\"\n    :content=\"{ side: 'top', sideOffset: 16, updatePositionStrategy: 'always' }\"\n  >\n    <div\n      class=\"flex items-center justify-center rounded-md border border-dashed border-accented text-sm aspect-video w-72\"\n      @pointerenter=\"open = true\"\n      @pointerleave=\"open = false\"\n      @pointermove=\"(ev: PointerEvent) => {\n        anchor.x = ev.clientX\n        anchor.y = ev.clientY\n      }\"\n    >\n      Hover me\n    </div>\n\n    <template #content>\n      <div class=\"p-4\">\n        {{ anchor.x.toFixed(0) }} - {{ anchor.y.toFixed(0) }}\n      </div>\n    </template>\n  </UPopover>\n</template>","source":"v4-nuxt-nuxt-ui-docs-app-components-content-examples-popover-popovercursorexample-vue-1-43-0916-0276","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script setup lang=\"ts\">\nconst items = Array.from({ length: 1000 }).map((_, index) => ({\n  id: index,\n  title: `Item ${index + 1}`,\n  src: `https://picsum.photos/640/480?v=${index}`,\n  width: 640,\n  height: 480\n}))\n\nconst gap = 16\nconst scrollArea = useTemplateRef('scrollArea')\nconst { width } = useElementSize(() => scrollArea.value?.$el)\n\nconst lanes = computed(() => Math.max(1, Math.min(4, Math.floor(width.value / 200))))\nconst laneWidth = computed(() => (width.value - (lanes.value - 1) * gap) / lanes.value)\nconst estimateSize = computed(() => laneWidth.value * (480 / 640))\n</script>\n\n<template>\n  <UScrollArea\n    ref=\"scrollArea\"\n    v-slot=\"{ item }\"\n    :items=\"items\"\n    :virtualize=\"{\n      gap,\n      lanes,\n      estimateSize,\n      skipMeasurement: true\n    }\"\n    class=\"w-full h-96 p-4\"\n  >\n    <img\n      :src=\"item.src\"\n      :alt=\"item.title\"\n      :width=\"item.width\"\n      :height=\"item.height\"\n      loading=\"lazy\"\n      class=\"rounded-md size-full object-cover\"\n    >\n  </UScrollArea>\n</template>","source":"v4-nuxt-nuxt-ui-docs-app-components-content-examples-scroll-area-scrollarearesponsivelanesexample-vue-1-41-0925-0277","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
