{"text":"<template>\n  <div>\n    <h1>ExportDefaultComponent</h1>\n    <pre>{{ myProp }}</pre>\n    <pre>{{ setupMyProp }}</pre>\n    <span\n      v-for=\"item in myArrayProp\"\n      :key=\"item\"\n    >{{ item }}\n    </span>\n    <span>myObjProp: {{ JSON.stringify(myObjProp) }}</span>\n  </div>\n</template>\n\n<!--\n<script setup lang=\"ts\">\nconst props = defineProps<{ myProp: string }>()\nconst setupMyProp = 'X' + props.myProp\n</script>\n\nFollowing script is a valid Vue 3 way to define a component\n-->\n\n<script lang=\"ts\">\nexport default {\n  props: {\n    myProp: {\n      type: String,\n      required: true,\n    },\n    myArrayProp: {\n      type: Array as PropType<string[]>,\n      default: () => ([]),\n    },\n    myObjProp: {\n      type: [Object, null, {}] as PropType<{ title: string } | null | object>,\n      default: () => ({}),\n    },\n  },\n  setup(props) {\n    return {\n      setupMyProp: 'X' + props.myProp,\n    }\n  },\n}\n</script>","source":"v4-nuxt-nuxt-test-utils-examples-app-vitest-full-components-exportdefaultcomponent-vue-1-46-0142-0271","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<template>\n  <div>\n    <h1>ExportDefineComponent</h1>\n    <pre>{{ myProp }}</pre>\n    <pre>{{ setupMyProp }}</pre>\n    <span\n      v-for=\"item in myArrayProp\"\n      :key=\"item\"\n    >{{ item }}</span>\n    <span>myObjProp: {{ JSON.stringify(myObjProp) }}</span>\n  </div>\n</template>\n\n<!--\n<script setup lang=\"ts\">\nconst props = defineProps<{ myProp: string }>()\nconst setupMyProp = 'X' + props.myProp\n</script>\n\nFollowing script is a valid Vue 3 way to define a component\n-->\n\n<script lang=\"ts\">\nexport default defineComponent({\n  props: {\n    myProp: {\n      type: String,\n      required: true,\n    },\n    myArrayProp: {\n      type: Array as PropType<string[]>,\n      default: () => ([]),\n    },\n    myObjProp: {\n      type: Object as PropType<{ title: string }>,\n      default: () => ({}),\n    },\n  },\n  setup(props) {\n    return {\n      setupMyProp: 'X' + props.myProp,\n    }\n  },\n})\n</script>","source":"v4-nuxt-nuxt-test-utils-examples-app-vitest-full-components-exportdefinecomponent-vue-1-45-0147-0272","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
