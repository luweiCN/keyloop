{"text":"<script setup lang=\"ts\">\nimport { onClickOutside, useVModel } from '@vueuse/core'\nimport { ref } from 'vue'\n\nconst props = withDefaults(defineProps<{\n  modelValue?: boolean\n  direction?: 'start' | 'end'\n}>(), {\n  direction: 'start',\n})\nconst emit = defineEmits<{ (...args: any): void }>()\n\nconst enabled = useVModel(props, 'modelValue', emit, { passive: true })\nconst el = ref<HTMLDivElement>()\n\nonClickOutside(el, () => {\n  enabled.value = false\n})\n</script>\n\n<template>\n  <div ref=\"el\" class=\"relative\">\n    <slot name=\"trigger\" :enabled=\"enabled\" :click=\"() => enabled = !enabled\">\n      <NButton @click=\"enabled = !enabled\">\n        Dropdown\n      </NButton>\n    </slot>\n\n    <div\n      class=\"absolute z-10 border n-border-base rounded n-bg-base shadow n-transition\"\n      :class=\"[enabled ? 'op-100' : 'op0 pointer-events-none -translate-y-1', direction === 'end' ? 'right-0' : 'left-0']\"\n    >\n      <slot />\n    </div>\n  </div>\n</template>","source":"v4-nuxt-nuxt-devtools-packages-devtools-ui-kit-src-components-ndropdown-vue-1-36-0071-0254","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":12}
