{"text":"<script setup lang=\"ts\">\nimport { useVModel } from '@vueuse/core'\n\nconst props = withDefaults(\n  defineProps<{\n    modelValue?: any\n    disabled?: boolean\n    options: { value: any, label: string }[]\n  }>(),\n  {\n    modelValue: undefined,\n    disabled: false,\n  },\n)\nconst emit = defineEmits<{ (...args: any): void }>()\nconst input = useVModel(props, 'modelValue', emit, { passive: true })\n</script>\n\n<template>\n  <fieldset\n    class=\"n-select-tabs flex flex-inline flex-wrap items-center border n-border-base rounded n-bg-base\"\n  >\n    <label\n      v-for=\"i, idx of options\"\n      :key=\"i.label\"\n      :disabled=\"disabled\"\n      class=\"relative n-border-base px-0.5em py-0.1em hover:n-bg-active\"\n      :class=\"[\n        idx ? 'border-l n-border-base ml--1px' : '',\n        i.value === input ? 'n-bg-active' : '',\n      ]\"\n      :title=\"i.label\"\n    >\n      <div\n        :class=\"[\n          i.value === input ? '' : 'op35',\n        ]\"\n      >{{ i.label }}</div>\n      <input\n        v-model=\"input\"\n        type=\"radio\"\n        :disabled=\"disabled\"\n        :value=\"i.value\"\n        :title=\"i.label\"\n        class=\"absolute inset-0 op-0.1\"\n      >\n    </label>\n  </fieldset>\n</template>","source":"v4-nuxt-nuxt-devtools-packages-devtools-ui-kit-src-components-nselecttabs-vue-1-49-0080-0265","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script setup lang=\"ts\">\nimport type { AssetInfo } from '~/../src/types'\n\ndefineProps<{\n  asset: AssetInfo\n  textContent?: string\n  detail?: boolean\n}>()\n</script>\n\n<template>\n  <div flex items-center justify-center of-hidden bg-active object-cover p1>\n    <template v-if=\"asset.type === 'image'\">\n      <img :src=\"asset.publicPath\">\n    </template>\n    <AssetFontPreview\n      v-else-if=\"asset.type === 'font'\"\n      :key=\"asset.publicPath\"\n      :asset=\"asset\" self-stretch p2 text-2xl\n    />\n    <div v-else-if=\"asset.type === 'text' && !textContent\" i-carbon-document text-3xl op20 />\n    <div v-else-if=\"asset.type === 'text' && textContent\" w-full self-start p4>\n      <pre max-h-10rem of-hidden text-xs font-mono v-text=\"textContent\" />\n    </div>\n    <div v-else-if=\"asset.type === 'video'\">\n      <video :src=\"asset.publicPath\" :autoplay=\"detail\" :controls=\"detail\" />\n    </div>\n    <div v-else-if=\"asset.type === 'audio'\">\n      <div v-if=\"!detail\" i-carbon-volume-up text-3xl op20 />\n      <audio v-else :src=\"asset.publicPath\" controls />\n    </div>\n    <div v-else i-carbon-help text-3xl op20 />\n  </div>\n</template>","source":"v4-nuxt-nuxt-devtools-packages-devtools-client-components-assetpreview-vue-1-34-0192-0266","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script setup lang=\"ts\">\nimport { wsConnectingDebounced } from '~/composables/rpc'\n\nfunction reload() {\n  window.location.reload()\n}\n</script>\n\n<template>\n  <Teleport to=\"body\">\n    <div\n      v-if=\"wsConnectingDebounced\"\n      flex=\"~ col justify-center items-center gap-4\"\n      fixed bottom-0 left-0 right-0 top-0 z-2147483646 n-glass-effect p5 text-lg backdrop-blur-4\n    >\n      <div flex-auto />\n      <div flex=\"~\" mt-8 items-center justify-center>\n        <NuxtLogo h-8 />\n      </div>\n      <div flex=\"~ gap-2\" items-center op50>\n        <NIcon icon=\"i-carbon-wifi-off\" />\n        Disconnected from Server\n      </div>\n      <div border=\"t base\" my2 h-1px w-10 />\n      <div flex=\"~ gap-2\" animate-pulse items-center text-xl text-yellow>\n        <NIcon icon=\"i-carbon-circle-dash\" animate-spin />\n        Retrying...\n      </div>\n      <div flex-auto />\n      <NButton n=\"sm yellow\" px2 py0 op40 @click=\"reload()\">\n        Reload DevTools Page\n      </NButton>\n    </div>\n  </Teleport>\n</template>","source":"v4-nuxt-nuxt-devtools-packages-devtools-client-components-disconnectindicator-vue-1-35-0228-0267","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script setup lang=\"ts\">\nimport type { StackFrame } from 'error-stack-parser-es'\nimport { useServerConfig } from '~/composables/state'\n\ndefineProps<{\n  stacktrace: StackFrame[]\n}>()\n\nconst MJS_EXTENSION_RE = /\\.m?js$/\n\nconst config = useServerConfig()\n\nfunction urlToFilepath(url: string) {\n  try {\n    let pathname = new URL(url).pathname\n    if (pathname.startsWith('/_nuxt/'))\n      pathname = pathname.slice(6)\n    if (pathname.startsWith('/@id/virtual:nuxt:'))\n      return `#build/${pathname.split('/.nuxt/')[1]}`.replace(MJS_EXTENSION_RE, '')\n    if (pathname.includes('/@fs/'))\n      return `/${pathname.split('/@fs/')[1]}`\n    return (config.value?.rootDir || '') + pathname\n  }\n  catch {\n    return url\n  }\n}\n</script>\n\n<template>\n  <div mt2 grid=\"~ cols-[max-content_1fr] gap-x-4\" font-mono>\n    <template v-for=\"item, idx of stacktrace\" :key=\"idx\">\n      <div text-right>\n        {{ item.functionName || `(anonymous)` }}\n      </div>\n      <div ws-nowrap>\n        <FilepathItem\n          v-if=\"item.fileName\"\n          :filepath=\"`${urlToFilepath(item.fileName)}:${item.lineNumber}:${item.columnNumber}`\"\n          subpath\n        />\n      </div>\n    </template>\n  </div>\n</template>","source":"v4-nuxt-nuxt-devtools-packages-devtools-client-components-stacktracelist-vue-1-45-0316-0268","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
{"text":"<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { definePageMeta } from '#imports'\nimport { useClient } from '~/composables/client'\nimport { useServerHooks } from '~/composables/state'\n\ndefinePageMeta({\n  icon: 'carbon-ibm-cloud-direct-link-2-connect',\n  title: 'Hooks',\n  category: 'advanced',\n})\n\nconst serverHooks = useServerHooks()\nconst client = useClient()\nconst clientHooks = computed(() => client.value?.metrics.clientHooks())\n</script>\n\n<template>\n  <div>\n    <NSectionBlock\n      v-if=\"clientHooks?.length\"\n      icon=\"carbon-ibm-cloud-direct-link-1-dedicated-hosting\"\n      text=\"Client Hooks\"\n      :description=\"`Total hooks: ${clientHooks.length}`\"\n      padding=\"pl4 pr6\"\n    >\n      <HooksTable :hooks=\"clientHooks\" />\n    </NSectionBlock>\n    <NSectionBlock\n      v-if=\"serverHooks?.length\"\n      icon=\"carbon-ibm-cloud-direct-link-2-dedicated\"\n      text=\"Server Hooks\"\n      :description=\"`Total hooks: ${serverHooks?.length}`\"\n      padding=\"pl4 pr6\"\n    >\n      <HooksTable :hooks=\"serverHooks\" />\n    </NSectionBlock>\n  </div>\n\n  <HelpFab>\n    <DocsHooks />\n  </HelpFab>\n</template>","source":"v4-nuxt-nuxt-devtools-packages-devtools-client-pages-modules-hooks-vue-1-43-0419-0269","language":"nuxt","syntax_language":"vue","framework":"nuxt","project":"keyloop-corpus","level":"file","difficulty":"hard","score":11}
