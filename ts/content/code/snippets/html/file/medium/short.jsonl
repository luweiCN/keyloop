{"text":"<script setup lang=\"ts\">\nimport theme from '#build/ui/badge'\n\nconst colors = Object.keys(theme.variants.color)\nconst variants = Object.keys(theme.variants.variant)\nconst sizes = Object.keys(theme.variants.size)\n\nconst attrs = reactive({\n  color: [theme.defaultVariants.color],\n  variant: [theme.defaultVariants.variant],\n  size: [theme.defaultVariants.size]\n})\n</script>\n\n<template>\n  <Navbar>\n    <USelect v-model=\"attrs.color\" :items=\"colors\" multiple />\n    <USelect v-model=\"attrs.variant\" :items=\"variants\" multiple />\n    <USelect v-model=\"attrs.size\" :items=\"sizes\" multiple />\n  </Navbar>\n\n  <Matrix v-slot=\"props\" :attrs=\"attrs\">\n    <UBadge label=\"Badge\" v-bind=\"props\" />\n    <UBadge icon=\"i-lucide-rocket\" label=\"Icon\" v-bind=\"props\" />\n    <UBadge :avatar=\"{ src: 'https://github.com/benjamincanac.png' }\" label=\"Avatar\" v-bind=\"props\" />\n    <UBadge icon=\"i-lucide-rocket\" v-bind=\"props\" />\n    <UBadge :avatar=\"{ src: 'https://github.com/benjamincanac.png' }\" v-bind=\"props\" />\n  </Matrix>\n</template>","source":"v4-html-nuxt-ui-playgrounds-nuxt-app-pages-components-badge-vue-1-30-0026","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"file","difficulty":"medium","score":9}
{"text":"<template>\n    <NuxtLayout>\n        <NuxtPage />\n    </NuxtLayout>\n</template>\n\n<script>\nimport EventBus from '@/app/AppEventBus';\n\nexport default {\n    mounted() {\n        EventBus.on('dark-mode-toggle', this.darkModeToggleListener);\n    },\n    beforeUnmount() {\n        EventBus.off('dark-mode-toggle', this.darkModeToggleListener);\n    },\n    methods: {\n        darkModeToggleListener(event) {\n            if (!document.startViewTransition) {\n                this.toggleDarkMode(event);\n\n                return;\n            }\n\n            document.startViewTransition(() => this.toggleDarkMode(event));\n        },\n        toggleDarkMode(event) {\n            const isDark = event.dark;\n\n            if (isDark) document.documentElement.classList.add('p-dark');\n            else document.documentElement.classList.remove('p-dark');\n\n            this.$appState.darkTheme = isDark;\n\n            EventBus.emit('dark-mode-toggle-complete');\n        }\n    }\n};\n</script>","source":"v4-html-primefaces-primevue-apps-showcase-app-vue-1-40-0001","language":"html","syntax_language":"vue","framework":"general","project":"keyloop-corpus","level":"file","difficulty":"medium","score":9}
