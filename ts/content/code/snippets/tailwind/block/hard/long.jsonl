{"text":"<UTimeline\n    v-else\n    :items=\"groupedByRelease\"\n    size=\"xs\"\n    :ui=\"{ root: '', wrapper: 'mt-0 pb-0', title: 'mb-1.5 flex items-center justify-between' }\"\n  >\n    <template #title=\"{ item }\">\n      <UBadge v-if=\"item.tag === 'unreleased'\" color=\"neutral\" variant=\"subtle\" :label=\"item.title\" class=\"w-12.5 justify-center\" />\n      <NuxtLink v-else :to=\"item.url\" target=\"_blank\" class=\"hover:underline\">\n        <UBadge variant=\"subtle\" :label=\"item.tag\" />\n      </NuxtLink>\n\n      <time v-if=\"item.published_at\" :datetime=\"item.published_at\" class=\"text-xs text-dimmed font-normal\">\n        {{ useTimeAgo(new Date(item.published_at)) }}\n      </time>\n    </template>\n\n    <template #description=\"{ item }\">\n      <ul class=\"flex flex-col gap-1.5\">\n        <li v-for=\"commit of item.commits\" :key=\"commit.sha\">\n          <MDC :value=\"normalizeCommitMessage(commit)\" class=\"text-sm [&_code]:text-xs\" unwrap=\"p\" />\n        </li>\n      </ul>\n    </template>\n  </UTimeline>","source":"v4-tailwind-nuxt-ui-docs-app-components-content-componentchangelog-vue-110-134-0002","language":"tailwind","syntax_language":"vue","framework":"tailwind","project":"keyloop-corpus","level":"block","difficulty":"hard","score":12}
{"text":"<ProseTbody>\n      <ProseTr v-for=\"prop in metaProps\" :key=\"prop.name\">\n        <ProseTd>\n          <ProseCode>\n            {{ prop.name }}\n          </ProseCode>\n        </ProseTd>\n        <ProseTd>\n          <HighlightInlineType v-if=\"prop.default\" :type=\"prop.default\" />\n        </ProseTd>\n        <ProseTd>\n          <HighlightInlineType v-if=\"prop.type\" :type=\"prop.type\" />\n\n          <MDC v-if=\"prop.description\" :value=\"prop.description\" class=\"text-toned mt-1\" :cache-key=\"`${kebabCase(route.path)}-${prop.name}-description`\" />\n\n          <ComponentPropsLinks v-if=\"prop.tags?.length\" :prop=\"prop\" />\n          <ComponentPropsSchema v-if=\"prop.schema\" :prop=\"prop\" :ignore=\"ignore\" />\n        </ProseTd>\n      </ProseTr>\n    </ProseTbody>","source":"v4-tailwind-nuxt-ui-docs-app-components-content-componentprops-vue-107-126-0003","language":"tailwind","syntax_language":"vue","framework":"tailwind","project":"keyloop-corpus","level":"block","difficulty":"hard","score":11}
{"text":"<ProseTr v-for=\"prop in metaProps\" :key=\"prop.name\">\n        <ProseTd>\n          <ProseCode>\n            {{ prop.name }}\n          </ProseCode>\n        </ProseTd>\n        <ProseTd>\n          <HighlightInlineType v-if=\"prop.default\" :type=\"prop.default\" />\n        </ProseTd>\n        <ProseTd>\n          <HighlightInlineType v-if=\"prop.type\" :type=\"prop.type\" />\n\n          <MDC v-if=\"prop.description\" :value=\"prop.description\" class=\"text-toned mt-1\" :cache-key=\"`${kebabCase(route.path)}-${prop.name}-description`\" />\n\n          <ComponentPropsLinks v-if=\"prop.tags?.length\" :prop=\"prop\" />\n          <ComponentPropsSchema v-if=\"prop.schema\" :prop=\"prop\" :ignore=\"ignore\" />\n        </ProseTd>\n      </ProseTr>","source":"v4-tailwind-nuxt-ui-docs-app-components-content-componentprops-vue-108-125-0004","language":"tailwind","syntax_language":"vue","framework":"tailwind","project":"keyloop-corpus","level":"block","difficulty":"hard","score":11}
{"text":"<ProseTable>\n    <ProseThead>\n      <ProseTr>\n        <ProseTh>\n          Slot\n        </ProseTh>\n        <ProseTh>\n          Type\n        </ProseTh>\n      </ProseTr>\n    </ProseThead>\n    <ProseTbody>\n      <ProseTr v-for=\"slot in (meta?.meta?.slots || [])\" :key=\"slot.name\">\n        <ProseTd>\n          <ProseCode>\n            {{ slot.name }}\n          </ProseCode>\n        </ProseTd>\n        <ProseTd>\n          <HighlightInlineType v-if=\"slot.type\" :type=\"slot.type\" />\n\n          <MDC v-if=\"slot.description\" :value=\"slot.description\" class=\"text-toned mt-1\" :cache-key=\"`${kebabCase(route.path)}-${slot.name}-description`\" />\n        </ProseTd>\n      </ProseTr>\n    </ProseTbody>\n  </ProseTable>","source":"v4-tailwind-nuxt-ui-docs-app-components-content-componentslots-vue-18-43-0005","language":"tailwind","syntax_language":"vue","framework":"tailwind","project":"keyloop-corpus","level":"block","difficulty":"hard","score":11}
{"text":"<div>\n    <ProseP>\n      By default, the <ProseCode>{{ props.default }}</ProseCode> locale is used.\n    </ProseP>\n    <div class=\"grid gap-6 grid-cols-2 md:grid-cols-3\">\n      <div v-for=\"locale in locales\" :key=\"locale.code\">\n        <div class=\"flex gap-3 items-center\">\n          <UAvatar size=\"xl\">\n            {{ getEmojiFlag(locale.code) }}\n          </UAvatar>\n\n          <div class=\"text-sm\">\n            <div class=\"font-semibold\">{{ locale.name }}</div>\n            <div class=\"mt-1\">Code: <ProseCode class=\"text-xs\">{{ locale.code }}</ProseCode></div>\n          </div>\n        </div>\n      </div>\n    </div>\n    <ProseNote to=\"https://github.com/nuxt/ui/tree/v4/src/runtime/locale\" target=\"_blank\">\n      If you need additional languages, you can contribute by creating a PR to add a new locale in <ProseCode>src/runtime/locale/</ProseCode>.\n    </ProseNote>\n    <ProseTip>\n      You can use the <ProseCode>nuxt-ui</ProseCode> CLI to create a new locale:\n\n      <ProsePre language=\"bash\">nuxt-ui make locale --code \"en\" --name \"English\"</ProsePre>\n    </ProseTip>\n  </div>","source":"v4-tailwind-nuxt-ui-docs-app-components-content-supportedlanguages-vue-70-96-0006","language":"tailwind","syntax_language":"vue","framework":"tailwind","project":"keyloop-corpus","level":"block","difficulty":"hard","score":12}
{"text":"<div v-if=\"page.authors?.length\" class=\"flex items-center gap-6 mt-6\">\n        <template v-for=\"author in page.authors\" :key=\"author.name\">\n          <ULink v-if=\"author.to\" :to=\"author.to\" target=\"_blank\" class=\"flex items-center gap-3 group\">\n            <UAvatar :src=\"author.avatar?.src\" :alt=\"author.name\" size=\"lg\" />\n            <div class=\"flex flex-col\">\n              <span class=\"text-sm font-medium text-highlighted\">{{ author.name }}</span>\n              <span class=\"text-xs text-muted group-hover:text-primary transition-colors\">@{{ author.to.split('/').pop() }}</span>\n            </div>\n          </ULink>\n          <div v-else class=\"flex items-center gap-3\">\n            <UAvatar :src=\"author.avatar?.src\" :alt=\"author.name\" size=\"lg\" />\n            <span class=\"text-sm font-medium text-highlighted\">{{ author.name }}</span>\n          </div>\n        </template>\n      </div>","source":"v4-tailwind-nuxt-ui-docs-app-pages-blog-slug-vue-79-93-0012","language":"tailwind","syntax_language":"vue","framework":"tailwind","project":"keyloop-corpus","level":"block","difficulty":"hard","score":12}
{"text":"<template #right>\n      <div>\n        <UContentToc\n          :links=\"page.body.toc?.links\"\n          class=\"z-2 lg:hidden mx-0!\"\n        />\n\n        <nav class=\"h-full sticky top-(--ui-header-height) max-h-[calc(100vh-var(--ui-header-height))] hidden lg:block\">\n          <ProseCodeTree\n            v-if=\"activePath\"\n            :model-value=\"activePath\"\n            class=\"lg:h-full my-0 rounded-none border-y-0 border-r-0 border-default\"\n            :items=\"items\"\n            expand-all\n            :ui=\"{ list: 'border-default', content: '[&>div>pre]:bg-muted/50 [&>div>pre]:border-default [&>div>pre]:rounded-none' }\"\n          />\n          <div v-else class=\"size-full border-l border-default flex items-center justify-center\">\n            <UIcon :name=\"appConfig.ui.icons.arrowDown\" class=\"size-12 text-dimmed animate-bounce\" />\n          </div>\n        </nav>\n      </div>\n    </template>","source":"v4-tailwind-nuxt-ui-docs-app-pages-blog-slug-vue-100-121-0013","language":"tailwind","syntax_language":"vue","framework":"tailwind","project":"keyloop-corpus","level":"block","difficulty":"hard","score":11}
{"text":"<div id=\"cursor2\" class=\"absolute z-10 pointer-events-none\" :style=\"{ opacity: 0 }\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"26\" height=\"26\" viewBox=\"0 0 24 24\" class=\"absolute top-0 left-0 drop-shadow-[0_1px_2px_rgb(0,0,0,0.25)] text-inverted\">\n        <path\n          fill=\"var(--ui-success)\"\n          stroke=\"currentColor\"\n          stroke-linecap=\"round\"\n          stroke-linejoin=\"round\"\n          stroke-width=\"1.5\"\n          d=\"M4.037 4.688a.495.495 0 0 1 .651-.651l16 6.5a.5.5 0 0 1-.063.947l-6.124 1.58a2 2 0 0 0-1.438 1.435l-1.579 6.126a.5.5 0 0 1-.947.063z\"\n        />\n      </svg>\n      <UBadge color=\"success\" class=\"absolute top-[18px] left-[18px] p-1 rounded-sm font-semibold leading-none\">\n        Sarah\n      </UBadge>\n    </div>","source":"v4-tailwind-nuxt-ui-docs-app-pages-figma-vue-107-121-0014","language":"tailwind","syntax_language":"vue","framework":"tailwind","project":"keyloop-corpus","level":"block","difficulty":"hard","score":12}
{"text":"<template #links>\n        <UButton v-for=\"link of page.hero.links\" :key=\"link.label\" v-bind=\"link\" size=\"xl\" />\n        <div class=\"w-full my-6\">\n          <USeparator class=\"w-1/2\" type=\"dashed\" />\n        </div>\n        <div class=\"flex flex-col gap-4\">\n          <Motion\n            v-for=\"(feature, index) in page.hero.features\"\n            :key=\"feature.title\"\n            as-child\n            :initial=\"{ opacity: 0, transform: 'translateX(-10px)' }\"\n            :while-in-view=\"{ opacity: 1, transform: 'translateX(0)' }\"\n            :transition=\"{ delay: 0.2 + 0.4 * index }\"\n            :in-view-options=\"{ once: true }\"\n          >\n            <UPageFeature v-bind=\"feature\" class=\"opacity-0\" />\n          </Motion>\n        </div>\n      </template>","source":"v4-tailwind-nuxt-ui-docs-app-pages-index-vue-80-98-0016","language":"tailwind","syntax_language":"vue","framework":"tailwind","project":"keyloop-corpus","level":"block","difficulty":"hard","score":12}
