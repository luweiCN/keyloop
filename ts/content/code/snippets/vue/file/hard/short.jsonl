{"text":"<template>\n  <div class=\"flex gap-2\">\n    <el-tag\n      v-for=\"item in items\"\n      :key=\"item.label\"\n      :type=\"item.type\"\n      effect=\"dark\"\n      round\n    >\n      {{ item.label }}\n    </el-tag>\n  </div>\n  <div class=\"flex gap-2 mt-4\">\n    <el-tag\n      v-for=\"item in items\"\n      :key=\"item.label\"\n      :type=\"item.type\"\n      effect=\"light\"\n      round\n    >\n      {{ item.label }}\n    </el-tag>\n  </div>\n  <div class=\"flex gap-2 mt-4\">\n    <el-tag\n      v-for=\"item in items\"\n      :key=\"item.label\"\n      :type=\"item.type\"\n      effect=\"plain\"\n      round\n    >\n      {{ item.label }}\n    </el-tag>\n  </div>\n</template>\n\n<script lang=\"ts\" setup>\nimport { ref } from 'vue'\n\nimport type { TagProps } from 'element-plus'\n\ntype Item = { type: TagProps['type']; label: string }\n\nconst items = ref<Array<Item>>([\n  { type: 'primary', label: 'Tag 1' },\n  { type: 'success', label: 'Tag 2' },\n  { type: 'info', label: 'Tag 3' },\n  { type: 'warning', label: 'Tag 4' },\n  { type: 'danger', label: 'Tag 5' },\n])\n</script>","source":"v4-vue-element-plus-element-plus-docs-examples-tag-rounded-vue-1-51-2689-0497","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
{"text":"<template>\n  <div class=\"flex gap-2\">\n    <span>Dark</span>\n    <el-tag\n      v-for=\"item in items\"\n      :key=\"item.label\"\n      :type=\"item.type\"\n      effect=\"dark\"\n    >\n      {{ item.label }}\n    </el-tag>\n  </div>\n  <div class=\"flex gap-2 mt-4\">\n    <span>Light</span>\n    <el-tag\n      v-for=\"item in items\"\n      :key=\"item.label\"\n      :type=\"item.type\"\n      effect=\"light\"\n    >\n      {{ item.label }}\n    </el-tag>\n  </div>\n  <div class=\"flex gap-2 mt-4\">\n    <span>Plain</span>\n    <el-tag\n      v-for=\"item in items\"\n      :key=\"item.label\"\n      :type=\"item.type\"\n      effect=\"plain\"\n    >\n      {{ item.label }}\n    </el-tag>\n  </div>\n</template>\n\n<script lang=\"ts\" setup>\nimport { ref } from 'vue'\n\nimport type { TagProps } from 'element-plus'\n\ntype Item = { type: TagProps['type']; label: string }\n\nconst items = ref<Array<Item>>([\n  { type: 'primary', label: 'Tag 1' },\n  { type: 'success', label: 'Tag 2' },\n  { type: 'info', label: 'Tag 3' },\n  { type: 'warning', label: 'Tag 4' },\n  { type: 'danger', label: 'Tag 5' },\n])\n</script>","source":"v4-vue-element-plus-element-plus-docs-examples-tag-theme-vue-1-51-2692-0498","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
{"text":"<template>\n  <el-button type=\"primary\" @click=\"open = true\">Begin Tour</el-button>\n\n  <el-divider />\n\n  <el-space>\n    <el-button ref=\"ref1\">Upload</el-button>\n    <el-button ref=\"ref2\" type=\"primary\">Save</el-button>\n    <el-button ref=\"ref3\" :icon=\"MoreFilled\" />\n  </el-space>\n\n  <el-tour v-model=\"open\">\n    <el-tour-step :target=\"ref1?.$el\" title=\"Upload File\">\n      <img\n        style=\"width: 240px\"\n        src=\"https://element-plus.org/images/element-plus-logo.svg\"\n        alt=\"tour.png\"\n      />\n      <div>Put you files here.</div>\n    </el-tour-step>\n    <el-tour-step\n      :target=\"ref2?.$el\"\n      title=\"Save\"\n      description=\"Save your changes\"\n    />\n    <el-tour-step\n      :target=\"ref3?.$el\"\n      title=\"Other Actions\"\n      description=\"Click to see other\"\n    />\n  </el-tour>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref } from 'vue'\nimport { MoreFilled } from '@element-plus/icons-vue'\n\nimport type { ButtonInstance } from 'element-plus'\n\nconst ref1 = ref<ButtonInstance>()\nconst ref2 = ref<ButtonInstance>()\nconst ref3 = ref<ButtonInstance>()\n\nconst open = ref(false)\n</script>","source":"v4-vue-element-plus-element-plus-docs-examples-tour-basic-vue-1-45-2710-0499","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
{"text":"<template>\n  <div class=\"q-pa-md\">\n    <div class=\"q-gutter-sm\">\n      <div>\n        <q-checkbox v-model=\"right\" label=\"Label on Right\" />\n      </div>\n\n      <div>\n        <q-checkbox left-label v-model=\"left\" label=\"Label on Left\" />\n      </div>\n\n      <div>\n        <q-checkbox\n          v-model=\"right2\"\n          label=\"Swipe\"\n          checked-icon=\"swipe_left\"\n          unchecked-icon=\"swipe_right\"\n          color=\"green\"\n          keep-color\n        />\n      </div>\n\n      <div>\n        <q-checkbox\n          left-label\n          v-model=\"left2\"\n          label=\"I agree\"\n          checked-icon=\"task_alt\"\n          unchecked-icon=\"highlight_off\"\n        />\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { ref } from 'vue'\n\nexport default {\n  setup() {\n    return {\n      left: ref(true),\n      right: ref(false),\n      left2: ref(true),\n      right2: ref(false)\n    }\n  }\n}\n</script>","source":"v4-vue-quasarframework-quasar-docs-src-examples-qcheckbox-label-vue-1-49-0451-0500","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
