{"text":"<template>\n  <v-container>\n    <v-row justify=\"center\">\n      <v-heatmap\n        :cell-size=\"[48, 40]\"\n        :columns=\"columns\"\n        :items=\"items\"\n        :rows=\"rows\"\n        :thresholds=\"thresholds\"\n      >\n        <template v-slot:cell=\"{ item }\">\n          <span class=\"v-heatmap__cell-text\">{{ item.value.toFixed(2) }}</span>\n        </template>\n      </v-heatmap>\n    </v-row>\n  </v-container>\n</template>\n\n<script setup>\n  const rows = ['A', 'B', 'C', 'D', 'E']\n  const columns = ['G1', 'G2', 'G3', 'G4', 'G5']\n\n  const thresholds = [\n    { min: 0.2, color: '#443983' },\n    { min: 0.4, color: '#21918c' },\n    { min: 0.6, color: '#35b779' },\n    { min: 0.8, color: '#fde725' },\n  ]\n\n  const items = rows.flatMap(row =>\n    columns.map(column => ({\n      row,\n      column,\n      value: Math.round(Math.random() * 100) / 100,\n    }))\n  )\n</script>","source":"v4-vue-vuetifyjs-vuetify-packages-docs-src-examples-v-heatmap-slot-cell-vue-1-37-0842-0508","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
