{"text":"<template>\n  <BForm>\n    <div class=\"row\">\n      <label\n        class=\"col-form-label col-lg-2 me-sm-2\"\n        for=\"inline-form-custom-select-pref\"\n        >Preference</label\n      >\n      <div class=\"col-lg-2\">\n        <BFormSelect\n          id=\"inline-form-custom-select-pref\"\n          v-model=\"customSelect\"\n          class=\"mb-2 me-sm-2 mb-sm-0\"\n          :options=\"[{text: 'Choose...', value: null}, 'One', 'Two', 'Three']\"\n        />\n      </div>\n      <BFormCheckbox class=\"col-form-label col-lg-3 mb-2 me-sm-2 mb-sm-0\"\n        >Remember my preference</BFormCheckbox\n      >\n      <div class=\"col-lg-2 col-form-label\">\n        <BButton variant=\"primary\">Save</BButton>\n      </div>\n    </div>\n  </BForm>\n</template>\n\n<script setup lang=\"ts\">\nimport {ref} from 'vue'\n\nconst customSelect = ref(null)\n</script>","source":"v4-vue-bootstrap-vue-next-bootstrap-vue-next-apps-docs-src-docs-components-demo-forminlineselect-vue-1-31-1002-0481","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":14}
{"text":"<template>\n  <div>\n    <h5>Default (icons at far right of cell)</h5>\n    <BTable\n      :items=\"items\"\n      :fields=\"fields\"\n    />\n\n    <h5 class=\"mt-4\">Icons at left of cell (<code>sort-icon-left</code>)</h5>\n    <BTable\n      :items=\"items\"\n      :fields=\"fields\"\n      sort-icon-left\n    />\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport type {TableFieldRaw, TableItem} from 'bootstrap-vue-next'\n\ninterface Person {\n  first_name: string\n  last_name: string\n  age: number\n  city: string\n}\n\nconst items: TableItem<Person>[] = [\n  {age: 40, first_name: 'Dickerson', last_name: 'Macdonald', city: 'New York'},\n  {age: 21, first_name: 'Larsen', last_name: 'Shaw', city: 'Los Angeles'},\n  {age: 89, first_name: 'Geneva', last_name: 'Wilson', city: 'Chicago'},\n  {age: 38, first_name: 'Jami', last_name: 'Carney', city: 'Houston'},\n]\n\nconst fields: Exclude<TableFieldRaw<Person>, string>[] = [\n  {key: 'first_name', label: 'First Name', sortable: true},\n  {key: 'last_name', label: 'Last Name', sortable: true},\n  {key: 'age', label: 'Age', sortable: true},\n  {key: 'city', label: 'City', sortable: true},\n]\n</script>","source":"v4-vue-bootstrap-vue-next-bootstrap-vue-next-apps-docs-src-docs-components-demo-tablesorticons-vue-1-41-1169-0488","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
{"text":"<template>\n    <section>\n        <p>Source loaded: {{ loadedSrc1 }}</p>\n        <b-image\n            src=\"https://picsum.photos/id/237/800/450.webp\"\n            webp-fallback=\".jpg\"\n            ratio=\"16by9\"\n            @load=\"onLoad1\"\n        ></b-image>\n        <br />\n        <p>Source loaded: {{ loadedSrc2 }}</p>\n        <b-image\n            src=\"https://picsum.photos/id/237/800/450.webp\"\n            webp-fallback=\"https://picsum.photos/id/1025/800/450.jpg\"\n            ratio=\"16by9\"\n            @load=\"onLoad2\"\n        ></b-image>\n    </section>\n</template>\n\n<script lang=\"ts\">\nimport { defineComponent } from \"vue\";\nimport { BImage } from \"buefy\";\n\nexport default defineComponent({\n    components: {\n        BImage,\n    },\n    data() {\n        return {\n            loadedSrc1: \"\" as string | undefined,\n            loadedSrc2: \"\" as string | undefined,\n        };\n    },\n    methods: {\n        onLoad1(event: Event, src?: string) {\n            this.loadedSrc1 = src;\n        },\n        onLoad2(event: Event, src?: string) {\n            this.loadedSrc2 = src;\n        },\n    },\n});\n</script>","source":"v4-vue-buefy-buefy-packages-docs-src-pages-components-image-examples-exwebp-vue-1-44-0596-0489","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
{"text":"import Vue from 'vue'\n\nimport d2Container from './d2-container'\nimport d2ContainerFrame from './d2-container-frame'\nimport d2LinkBtn from './d2-link-btn'\n\n// 注意 有些组件使用异步加载会有影响\nVue.component('d2-container', d2Container)\nVue.component('d2-container-frame', d2ContainerFrame)\nVue.component('d2-link-btn', d2LinkBtn)\nVue.component('d2-count-up', () => import('./d2-count-up'))\nVue.component('d2-highlight', () => import('./d2-highlight'))\nVue.component('d2-icon', () => import('./d2-icon'))\nVue.component('d2-icon-svg', () => import('./d2-icon-svg/index.vue'))\nVue.component('d2-icon-select', () => import('./d2-icon-select/index.vue'))\nVue.component('d2-icon-svg-select', () => import('./d2-icon-svg-select/index.vue'))\nVue.component('d2-markdown', () => import('./d2-markdown'))\nVue.component('d2-module-index-banner', () => import('./d2-module-index-banner'))\nVue.component('d2-module-index-menu', () => import('./d2-module-index-menu'))\nVue.component('d2-quill', () => import('./d2-quill'))\nVue.component('d2-scrollbar', () => import('./d2-scrollbar'))\nVue.component('d2-ueditor', () => import('./d2-ueditor'))","source":"v4-vue-d2-projects-d2-admin-src-components-index-js-1-22-0052-0490","language":"vue","syntax_language":"javascript","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
{"text":"<template>\n  <el-tooltip effect=\"dark\" :content=\"tooltipContent\" placement=\"bottom\">\n    <el-button class=\"d2-ml-0 d2-mr btn-text can-hover\" type=\"text\" @click=\"handleClick\">\n      <el-badge v-if=\"logLength > 0\" :max=\"99\" :value=\"logLengthError\" :is-dot=\"logLengthError === 0\">\n        <d2-icon :name=\"logLengthError === 0 ? 'dot-circle-o' : 'bug'\" style=\"font-size: 20px\"/>\n      </el-badge>\n      <d2-icon v-else name=\"dot-circle-o\" style=\"font-size: 20px\"/>\n    </el-button>\n  </el-tooltip>\n</template>\n\n<script>\nimport { mapGetters, mapMutations } from 'vuex'\nexport default {\n  computed: {\n    ...mapGetters('d2admin', {\n      logLength: 'log/length',\n      logLengthError: 'log/lengthError'\n    }),\n    tooltipContent () {\n      return this.logLength === 0\n        ? '没有日志或异常'\n        : `${this.logLength} 条日志${this.logLengthError > 0\n          ? ` | 包含 ${this.logLengthError} 个异常`\n          : ''}`\n    }\n  },\n  methods: {\n    ...mapMutations('d2admin/log', [\n      'clean'\n    ]),\n    handleClick () {\n      this.$router.push({\n        name: 'log'\n      })\n    }\n  }\n}\n</script>","source":"v4-vue-d2-projects-d2-admin-src-layout-header-aside-components-header-log-index-vue-1-39-0064-0491","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
{"text":"<template>\n  <d2-container type=\"card\">\n    <el-row :gutter=\"20\">\n      <el-col :span=\"14\">\n        <d2-ueditor v-model=\"text\"/>\n      </el-col>\n      <el-col :span=\"10\">\n        <el-card v-if=\"text\" shadow=\"never\" style=\"border: 1px solid #d4d4d4;\">\n          <template slot=\"header\">Result</template>\n          <div v-html=\"text\" style=\"margin: -20px 0px;\"></div>\n        </el-card>\n      </el-col>\n    </el-row>\n    <template slot=\"footer\">\n      <el-button type=\"primary\" @click=\"text += text\">\n        <d2-icon name=\"copy\"/> 当前内容 x2\n      </el-button>\n      <el-button type=\"danger\" @click=\"text = ''\">\n        <d2-icon name=\"trash-o\"/> 清空\n      </el-button>\n    </template>\n  </d2-container>\n</template>\n\n<script>\nexport default {\n  data () {\n    return {\n      text: '<p>Hello World</p>'\n    }\n  }\n}\n</script>","source":"v4-vue-d2-projects-d2-admin-src-views-demo-components-editor-ueditor-index-vue-1-33-0139-0492","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
{"text":"<template>\n  <div>\n    <el-radio-group v-model=\"radio1\">\n      <el-radio value=\"1\" size=\"large\" border>Option A</el-radio>\n      <el-radio value=\"2\" size=\"large\" border>Option B</el-radio>\n    </el-radio-group>\n  </div>\n  <div style=\"margin-top: 20px\">\n    <el-radio-group v-model=\"radio2\">\n      <el-radio value=\"1\" border>Option A</el-radio>\n      <el-radio value=\"2\" border>Option B</el-radio>\n    </el-radio-group>\n  </div>\n  <div style=\"margin-top: 20px\">\n    <el-radio-group v-model=\"radio3\" size=\"small\">\n      <el-radio value=\"1\" border>Option A</el-radio>\n      <el-radio value=\"2\" border disabled>Option B</el-radio>\n    </el-radio-group>\n  </div>\n  <div style=\"margin-top: 20px\">\n    <el-radio-group v-model=\"radio4\" size=\"small\" disabled>\n      <el-radio value=\"1\" border>Option A</el-radio>\n      <el-radio value=\"2\" border>Option B</el-radio>\n    </el-radio-group>\n  </div>\n</template>\n\n<script lang=\"ts\" setup>\nimport { ref } from 'vue'\n\nconst radio1 = ref('1')\nconst radio2 = ref('1')\nconst radio3 = ref('1')\nconst radio4 = ref('1')\n</script>","source":"v4-vue-element-plus-element-plus-docs-examples-radio-with-borders-vue-1-35-2488-0493","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
{"text":"<template>\n  <el-switch\n    v-model=\"value1\"\n    class=\"mb-2\"\n    active-text=\"Pay by month\"\n    inactive-text=\"Pay by year\"\n  />\n  <br />\n  <el-switch\n    v-model=\"value2\"\n    class=\"mb-2\"\n    style=\"--el-switch-on-color: #13ce66; --el-switch-off-color: #ff4949\"\n    active-text=\"Pay by month\"\n    inactive-text=\"Pay by year\"\n  />\n  <br />\n  <el-switch\n    v-model=\"value3\"\n    inline-prompt\n    active-text=\"是\"\n    inactive-text=\"否\"\n  />\n  <el-switch\n    v-model=\"value4\"\n    class=\"ml-2\"\n    inline-prompt\n    style=\"--el-switch-on-color: #13ce66; --el-switch-off-color: #ff4949\"\n    active-text=\"Y\"\n    inactive-text=\"N\"\n  />\n  <el-switch\n    v-model=\"value6\"\n    class=\"ml-2\"\n    width=\"60\"\n    inline-prompt\n    active-text=\"超出省略\"\n    inactive-text=\"超出省略\"\n  />\n  <el-switch\n    v-model=\"value5\"\n    class=\"ml-2\"\n    inline-prompt\n    style=\"--el-switch-on-color: #13ce66; --el-switch-off-color: #ff4949\"\n    active-text=\"完整展示多个内容\"\n    inactive-text=\"多个内容\"\n  />\n</template>\n\n<script lang=\"ts\" setup>\nimport { ref } from 'vue'\n\nconst value1 = ref(true)\nconst value2 = ref(true)\nconst value3 = ref(true)\nconst value4 = ref(true)\nconst value5 = ref(true)\nconst value6 = ref(true)\n</script>","source":"v4-vue-element-plus-element-plus-docs-examples-switch-text-description-vue-1-58-2590-0494","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
{"text":"<template>\n  <el-table :data=\"tableData\" style=\"width: 100%\">\n    <el-table-column type=\"index\" :index=\"indexMethod\" />\n    <el-table-column prop=\"date\" label=\"Date\" width=\"180\" />\n    <el-table-column prop=\"name\" label=\"Name\" width=\"180\" />\n    <el-table-column prop=\"address\" label=\"Address\" />\n  </el-table>\n</template>\n\n<script lang=\"ts\" setup>\nconst indexMethod = (index: number) => {\n  return index * 2\n}\nconst tableData = [\n  {\n    date: '2016-05-03',\n    name: 'Tom',\n    state: 'California',\n    city: 'Los Angeles',\n    address: 'No. 189, Grove St, Los Angeles',\n    zip: 'CA 90036',\n    tag: 'Home',\n  },\n  {\n    date: '2016-05-02',\n    name: 'Tom',\n    state: 'California',\n    city: 'Los Angeles',\n    address: 'No. 189, Grove St, Los Angeles',\n    zip: 'CA 90036',\n    tag: 'Office',\n  },\n  {\n    date: '2016-05-04',\n    name: 'Tom',\n    state: 'California',\n    city: 'Los Angeles',\n    address: 'No. 189, Grove St, Los Angeles',\n    zip: 'CA 90036',\n    tag: 'Home',\n  },\n  {\n    date: '2016-05-01',\n    name: 'Tom',\n    state: 'California',\n    city: 'Los Angeles',\n    address: 'No. 189, Grove St, Los Angeles',\n    zip: 'CA 90036',\n    tag: 'Office',\n  },\n]\n</script>","source":"v4-vue-element-plus-element-plus-docs-examples-table-custom-index-vue-1-52-2628-0495","language":"vue","syntax_language":"vue","framework":"vue","project":"keyloop-corpus","level":"file","difficulty":"hard","score":13}
