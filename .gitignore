# Local editor and OS noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# TypeScript/Bun build artifacts
node_modules/
dist/
coverage/

# Local runtime data. KeyLoop writes to ~/.keyloop by default, but keep
# redirected local data out of the repository as well.
.keyloop/
sessions.jsonl

# Corpus collection workspaces (hundreds of MB of raw scraped data).
# Runtime content lives in contents; these are pipeline inputs only.
/content/corpus-v2/
/content/corpus-v3/
/content/corpus-v4/
/content/final/
/content/reports/
/raw/

# Everyday-reading pipeline intermediates (sources for contents builds).
/contents/everyday_reading_candidates.json
/contents/everyday_reading_seed.json
/contents/everyday_reading_translated/
/contents/everyday_reading_translation_batches/

# Stray artifacts
/--verbose
__pycache__/
.claude/

# Corpus rebuild intermediates (candidates + per-item reviews).
/content/corpus-rebuild/

# Rust build artifacts
target/
